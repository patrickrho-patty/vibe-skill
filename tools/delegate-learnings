#!/usr/bin/env python3
"""
delegate-learnings — capture and analyze correction patterns
Records diff-of-diff when orchestrator corrects harness output.

Usage:
  delegate-learnings record <workdir> <harness> <original-prompt> <correction-diff-file>
  delegate-learnings analyze [--workdir DIR] [--harness NAME] [--since DAYS]
  delegate-learnings suggest <workdir> <harness> [task-type]
"""
import sys, os, json, re
from pathlib import Path
from datetime import datetime, timezone, timedelta

KST = timezone(timedelta(hours=9))
from collections import Counter

def get_log_path(workdir: str) -> Path:
    log = Path(workdir) / '.delegate' / 'learnings.jsonl'
    log.parent.mkdir(parents=True, exist_ok=True)
    if not log.exists():
        log.touch()
    return log

def record(workdir: str, harness: str, original_prompt: str, correction_diff_file: str):
    """Record a learning from a correction."""
    LOG = get_log_path(workdir)

    # Read the correction diff
    diff_content = ''
    try:
        diff_content = Path(correction_diff_file).read_text()[:5000]
    except Exception as e:
        print(f"Warning: could not read diff file: {e}", file=sys.stderr)

    # Classify the correction type
    correction_type = classify_correction(diff_content)

    # Extract affected files from diff
    affected_files = re.findall(r'^[+-]{3}\s+[ab]/(.+)$', diff_content, re.M)
    affected_files = list(set(affected_files))

    entry = {
        'ts': datetime.now(KST).strftime('%Y-%m-%dT%H:%M:%S+09:00'),
        'workdir': workdir,
        'project': os.path.basename(workdir),
        'harness': harness,
        'original_prompt_snippet': original_prompt[:200],
        'correction_type': correction_type,
        'affected_files': affected_files,
        'diff_size': len(diff_content),
        'diff_lines': diff_content.count('\n'),
    }

    with open(LOG, 'a') as f:
        f.write(json.dumps(entry) + '\n')

    print(f"[learning] Recorded: {correction_type} correction for {harness} ({len(affected_files)} file(s))")

def classify_correction(diff: str) -> str:
    """Classify what type of correction was made."""
    if re.search(r'^\+.*import', diff, re.M) and re.search(r'^-.*import', diff, re.M):
        return 'import_fix'
    if re.search(r'^\+.*import', diff, re.M) and not re.search(r'^-.*import', diff, re.M):
        return 'missing_import'
    if re.search(r'^-.*\n-.*\n-.*\n-.*\n-', diff, re.M):
        return 'duplicate_removal'
    if 'def ' in diff and diff.count('+def ') == 0 and diff.count('-def ') > 0:
        return 'function_removal'
    if 'def ' in diff and diff.count('+def ') > 0 and diff.count('-def ') == 0:
        return 'function_addition'
    if re.search(r'[<>=]{7}', diff):
        return 'conflict_resolution'
    if len(diff.splitlines()) < 10:
        return 'minor_fix'
    return 'general_correction'

def analyze(workdir: str = '', harness_filter: str = '', since_days: int = 30):
    """Analyze correction patterns."""
    LOG = get_log_path(workdir or os.getcwd())
    cutoff = datetime.now(KST) - timedelta(days=since_days)

    try:
        entries = [json.loads(line) for line in LOG.read_text().splitlines() if line.strip()]
    except Exception:
        entries = []

    # Filter
    filtered = []
    for e in entries:
        try:
            ts = datetime.fromisoformat(e['ts'].replace('Z', '+00:00'))
            if ts < cutoff:
                continue
        except (KeyError, ValueError):
            continue
        if harness_filter and e.get('harness') != harness_filter:
            continue
        filtered.append(e)

    if not filtered:
        print("[learning] No learnings recorded in the given timeframe")
        return

    # Aggregate
    print(f"\n=== LEARNING ANALYSIS ({len(filtered)} corrections, last {since_days} days) ===\n")

    # By harness
    by_harness = Counter(e.get('harness', 'unknown') for e in filtered)
    print("Corrections by harness:")
    for h, count in by_harness.most_common():
        print(f"  {h}: {count}")

    # By correction type
    print("\nCorrection types:")
    by_type = Counter(e.get('correction_type', 'unknown') for e in filtered)
    for t, count in by_type.most_common():
        pct = count / len(filtered) * 100
        print(f"  {t}: {count} ({pct:.0f}%)")

    # Most corrected files
    all_files = []
    for e in filtered:
        all_files.extend(e.get('affected_files', []))
    if all_files:
        print("\nMost corrected files:")
        for f, count in Counter(all_files).most_common(5):
            print(f"  {f}: {count} corrections")

    print("")

def suggest(workdir: str, harness: str, task_type: str = ''):
    """Suggest prompt improvements based on learnings."""
    LOG = get_log_path(workdir)
    cutoff = datetime.now(KST) - timedelta(days=30)

    try:
        entries = [json.loads(line) for line in LOG.read_text().splitlines() if line.strip()]
    except Exception:
        entries = []

    # Filter to this harness, recent
    filtered = []
    for e in entries:
        try:
            ts = datetime.fromisoformat(e['ts'].replace('Z', '+00:00'))
            if ts < cutoff:
                continue
        except (KeyError, ValueError):
            continue
        if e.get('harness') == harness:
            filtered.append(e)

    if not filtered:
        print(f"[learning] No learnings for harness '{harness}' — no suggestions")
        return

    by_type = Counter(e.get('correction_type', 'unknown') for e in filtered)

    print(f"\n=== PROMPT SUGGESTIONS FOR {harness.upper()} ===\n")
    print("Based on recent correction patterns, add these to your prompts:\n")

    suggestions = {
        'missing_import': "CONSTRAINT: After adding any new function call, verify the import exists at the top of the file.",
        'import_fix': "CONSTRAINT: Check existing imports before modifying. Do not change import paths that already work.",
        'duplicate_removal': "CONSTRAINT: Before writing any function, grep the file to confirm it doesn't already exist.",
        'function_addition': "CONSTRAINT: After adding a function, ensure it is called from the appropriate location.",
        'conflict_resolution': "CONSTRAINT: Check for merge conflict markers (<<<<<<, ======, >>>>>>) before completing.",
        'minor_fix': "VERIFY: After each edit, re-read the modified lines to confirm correctness.",
        'general_correction': "VERIFY: Read back the full modified function after editing to confirm no typos or logic errors.",
    }

    for correction_type, count in by_type.most_common():
        if correction_type in suggestions:
            pct = count / len(filtered) * 100
            print(f"  [{pct:.0f}% of corrections] {suggestions[correction_type]}")

    print("")

def main():
    if len(sys.argv) < 2:
        print(__doc__, file=sys.stderr)
        sys.exit(1)

    action = sys.argv[1]

    if action == 'record':
        if len(sys.argv) < 6:
            print("Usage: delegate-learnings record <workdir> <harness> <original-prompt> <correction-diff-file>", file=sys.stderr)
            sys.exit(1)
        record(sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5])

    elif action == 'analyze':
        workdir = ''
        harness = ''
        since = 30
        args = sys.argv[2:]
        i = 0
        while i < len(args):
            if args[i] == '--workdir' and i + 1 < len(args):
                workdir = args[i + 1]
                i += 2
            elif args[i] == '--harness' and i + 1 < len(args):
                harness = args[i + 1]
                i += 2
            elif args[i] == '--since' and i + 1 < len(args):
                since = int(args[i + 1])
                i += 2
            else:
                i += 1
        analyze(workdir, harness, since)

    elif action == 'suggest':
        if len(sys.argv) < 4:
            print("Usage: delegate-learnings suggest <workdir> <harness> [task-type]", file=sys.stderr)
            sys.exit(1)
        workdir = sys.argv[2]
        harness = sys.argv[3]
        task_type = sys.argv[4] if len(sys.argv) > 4 else ''
        suggest(workdir, harness, task_type)

    else:
        print(f"Unknown action: {action}", file=sys.stderr)
        print(__doc__, file=sys.stderr)
        sys.exit(1)

if __name__ == '__main__':
    main()
