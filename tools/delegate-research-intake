#!/usr/bin/env python3
"""
delegate-research-intake — SOTA reviews and acts on open research findings.

Usage:
  delegate-research-intake pending                              List open findings for review
  delegate-research-intake deferred                             List deferred findings due for review
  delegate-research-intake graduate <id> [options]              Graduate a finding after review
  delegate-research-intake summary                              Show stats

Options for graduate:
  --action <type>       fix|refactor|doc|improve|ack|dismiss|defer
  --detail "..."        What the SOTA did after reading this finding
  --comment "..."       Any additional notes
  --model <name>        Which model performed the review (default: from env)
  --review-by "..."     When to revisit (defer only). e.g. "2026-06-01", "after R8 ships", "next sprint"

Actions:
  fix        Fixed a bug based on this research
  refactor   Refactored code to align with the research
  doc        Wrote documentation or a plan for future improvement
  improve    Implemented an improvement suggested by the research
  ack        Acknowledged — useful context, no code action needed now
  dismiss    Not relevant, not accurate, or already addressed
  defer      Not actionable now — revisit later (requires --review-by)
"""
import json
import os
import sys
import textwrap
import fcntl
from datetime import datetime, timezone, timedelta

KST = timezone(timedelta(hours=9))
from pathlib import Path


def get_research_path(workdir: str) -> Path:
    return Path(workdir) / '.delegate' / 'research.jsonl'


def load_findings(workdir: str) -> list:
    log = get_research_path(workdir)
    if not log.exists():
        return []
    findings = []
    for line in log.read_text().splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            findings.append(json.loads(line))
        except Exception:
            continue
    return findings


def save_findings(workdir: str, findings: list):
    log = get_research_path(workdir)
    tmp = log.with_suffix('.tmp')
    with open(tmp, 'w') as fh:
        for f in findings:
            fh.write(json.dumps(f) + '\n')
        fh.flush()
        os.fsync(fh.fileno())
    os.replace(str(tmp), str(log))


VALID_ACTIONS = {'fix', 'refactor', 'doc', 'improve', 'ack', 'dismiss', 'defer'}

ACTION_LABELS = {
    'fix': 'Bug Fix',
    'refactor': 'Code Refactor',
    'doc': 'Documentation / Future Plan',
    'improve': 'Improvement Implemented',
    'ack': 'Acknowledged',
    'dismiss': 'Dismissed',
    'defer': 'Deferred',
}


def resolve_workdir(args: list) -> tuple:
    if args and not args[0].startswith('-') and os.path.isdir(args[0]):
        return args[0], args[1:]
    return os.getcwd(), list(args)


def print_finding(f: dict):
    sev = f.get('severity', '?').upper()
    fid = f.get('id', '?')
    topic = f.get('topic', '?')
    date = f.get('timestamp', '?')[:10]
    cat = f.get('category', '?')
    effort = f.get('effort', '?')
    filepath = f.get('file', '?')
    finding = f.get('finding', '?')
    sources = f.get('sources', [])

    print(f"\n{'─' * 72}")
    print(f"  [{sev}] {topic}")
    print(f"  ID: {fid}  |  {cat}  |  effort: {effort}  |  {date}")
    print(f"  File: {filepath}")
    print(f"{'─' * 72}")

    wrapped = textwrap.fill(finding, width=70, initial_indent='  ', subsequent_indent='  ')
    print(wrapped)

    if sources:
        print()
        print("  References:")
        for i, src in enumerate(sources, 1):
            print(f"    [{i}] {src}")


def cmd_pending(workdir: str):
    findings = load_findings(workdir)
    open_findings = [f for f in findings if f.get('status', 'open') == 'open']

    # Also include deferred findings that are due for review
    now_str = datetime.now(KST).strftime('%Y-%m-%d')
    deferred_due = []
    for f in findings:
        if f.get('status') != 'deferred':
            continue
        review_by = f.get('review_by', '')
        if len(review_by) >= 10 and review_by[:10] <= now_str:
            deferred_due.append(f)
        elif not review_by:
            deferred_due.append(f)

    if not open_findings and not deferred_due:
        print("No open findings to review.")
        return

    sev_order = {'high': 0, 'medium': 1, 'low': 2}
    open_findings.sort(key=lambda f: (sev_order.get(f.get('severity', 'low'), 3), f.get('timestamp', '')))

    if open_findings:
        print(f"\n{'=' * 72}")
        print(f"  PENDING RESEARCH — {len(open_findings)} new finding(s)")
        print(f"{'=' * 72}")
        for f in open_findings:
            print_finding(f)

    if deferred_due:
        print(f"\n{'=' * 72}")
        print(f"  DEFERRED — DUE FOR REVIEW ({len(deferred_due)})")
        print(f"{'=' * 72}")
        for f in deferred_due:
            print_finding(f)
            print(f"  Originally deferred: {f.get('deferred_at', '?')[:10]}")
            print(f"  Review-by: {f.get('review_by', '?')}")
            print(f"  Reason: {f.get('intake_detail', '?')[:120]}")

    total = len(open_findings) + len(deferred_due)
    print(f"\n{'=' * 72}")
    print(f"  Total actionable: {total} ({len(open_findings)} new, {len(deferred_due)} deferred-due)")
    print(f"\nTo graduate:")
    print(f'  delegate-research-intake graduate <id> --action <type> --detail "what you did"')
    print(f'  Actions: fix, refactor, doc, improve, ack, dismiss, defer')
    print(f'  Defer requires: --review-by "when to revisit"')
    print()


def cmd_deferred(workdir: str):
    findings = load_findings(workdir)
    deferred = [f for f in findings if f.get('status') == 'deferred']

    if not deferred:
        print("No deferred findings.")
        return

    now_str = datetime.now(KST).strftime('%Y-%m-%d')

    due = []
    not_due = []
    for f in deferred:
        review_by = f.get('review_by', '')
        # If review_by looks like a date and it's past, it's due
        if len(review_by) >= 10 and review_by[:10] <= now_str:
            due.append(f)
        elif not review_by:
            due.append(f)
        else:
            not_due.append(f)

    if due:
        print(f"\n{'=' * 72}")
        print(f"  DEFERRED — DUE FOR REVIEW ({len(due)})")
        print(f"{'=' * 72}")
        for f in due:
            print_finding(f)
            print(f"  Review-by: {f.get('review_by', '?')}")
            print(f"  Deferred reason: {f.get('intake_detail', '?')}")

    if not_due:
        print(f"\n{'=' * 72}")
        print(f"  DEFERRED — NOT YET DUE ({len(not_due)})")
        print(f"{'=' * 72}")
        for f in not_due:
            fid = f.get('id', '?')
            topic = f.get('topic', '?')[:45]
            review_by = f.get('review_by', '?')
            print(f"  {fid}  {topic}  (review by: {review_by})")

    print(f"\n{'=' * 72}")
    print(f"Total deferred: {len(deferred)} ({len(due)} due, {len(not_due)} not yet)")
    print()


def cmd_graduate(workdir: str, finding_id: str, action: str, detail: str,
                 comment: str, model: str, review_by: str):
    if action not in VALID_ACTIONS:
        print(f"Invalid action: {action}", file=sys.stderr)
        print(f"Valid actions: {', '.join(sorted(VALID_ACTIONS))}", file=sys.stderr)
        sys.exit(1)

    if action == 'defer' and not review_by:
        print("--review-by is required for defer action.", file=sys.stderr)
        print('Example: --review-by "2026-06-01" or --review-by "after R8 ships"', file=sys.stderr)
        sys.exit(1)

    findings = load_findings(workdir)
    matched = False
    now = datetime.now(KST).strftime('%Y-%m-%dT%H:%M:%S+09:00')

    for f in findings:
        if f.get('id', '').startswith(finding_id):
            if action == 'defer':
                f['status'] = 'deferred'
                f['deferred_at'] = now
                f['deferred_by'] = model
                f['review_by'] = review_by
            else:
                f['status'] = 'graduated'
                f['graduated_at'] = now
                f['graduated_by'] = model

            f['intake_action'] = action
            f['intake_detail'] = detail
            if comment:
                f['intake_comment'] = comment

            matched = True
            label = ACTION_LABELS.get(action, action)
            actual_id = f.get('id', finding_id)
            if action == 'defer':
                print(f"Deferred [{actual_id}]: review by {review_by}")
            else:
                print(f"Graduated [{actual_id}]: {label}")
            print(f"  Topic:   {f.get('topic', '?')}")
            print(f"  Action:  {action} — {detail[:200]}")
            if comment:
                print(f"  Comment: {comment[:200]}")
            if review_by:
                print(f"  Review:  {review_by}")
            print(f"  By:      {model}")
            print(f"  At:      {now}")
            break

    if not matched:
        print(f"Finding '{finding_id}' not found.", file=sys.stderr)
        all_ids = [f.get('id', '?') for f in findings]
        if all_ids:
            print(f"Available IDs: {', '.join(all_ids[:10])}", file=sys.stderr)
        sys.exit(1)

    save_findings(workdir, findings)


def cmd_summary(workdir: str):
    findings = load_findings(workdir)
    if not findings:
        print("No research findings.")
        return

    open_count = sum(1 for f in findings if f.get('status', 'open') == 'open')
    graduated = [f for f in findings if f.get('status') == 'graduated']
    deferred = [f for f in findings if f.get('status') == 'deferred']
    dismissed = sum(1 for f in findings if f.get('status') == 'dismissed')
    applied = sum(1 for f in findings if f.get('status') == 'applied')

    print(f"\nResearch Summary")
    print(f"  Open:      {open_count}")
    print(f"  Graduated: {len(graduated)}")
    print(f"  Deferred:  {len(deferred)}")
    print(f"  Applied:   {applied}")
    print(f"  Dismissed: {dismissed}")
    print(f"  Total:     {len(findings)}")

    if graduated:
        action_counts = {}
        for f in graduated:
            a = f.get('intake_action', '?')
            action_counts[a] = action_counts.get(a, 0) + 1

        print(f"\n  Graduation breakdown:")
        for a, c in sorted(action_counts.items(), key=lambda x: -x[1]):
            label = ACTION_LABELS.get(a, a)
            print(f"    {label}: {c}")

        graduated.sort(key=lambda f: f.get('graduated_at', ''), reverse=True)
        print(f"\n  Recent graduations:")
        for f in graduated[:5]:
            date = f.get('graduated_at', '?')[:10]
            action = f.get('intake_action', '?')
            topic = f.get('topic', '?')[:40]
            detail = f.get('intake_detail', '')[:50]
            print(f"    [{date}] {action}: {topic}")
            if detail:
                print(f"             {detail}")

    if deferred:
        now_str = datetime.now(KST).strftime('%Y-%m-%d')
        due_count = sum(1 for f in deferred if (f.get('review_by', '') or '')[:10] <= now_str)
        print(f"\n  Deferred: {len(deferred)} total, {due_count} due for review")
        for f in deferred[:5]:
            topic = f.get('topic', '?')[:40]
            review_by = f.get('review_by', '?')
            print(f"    {topic} (review by: {review_by})")

    print()


def main():
    args = sys.argv[1:]
    if not args:
        print(__doc__.strip())
        sys.exit(1)

    subcmd = args[0]
    rest = args[1:]

    if subcmd == 'pending':
        workdir, _ = resolve_workdir(rest)
        cmd_pending(workdir)

    elif subcmd == 'deferred':
        workdir, _ = resolve_workdir(rest)
        cmd_deferred(workdir)

    elif subcmd == 'summary':
        workdir, _ = resolve_workdir(rest)
        cmd_summary(workdir)

    elif subcmd == 'graduate':
        if not rest:
            print("Usage: delegate-research-intake graduate <id> --action <type> --detail \"...\"", file=sys.stderr)
            sys.exit(1)

        finding_id = rest[0]
        remaining = rest[1:]
        workdir, remaining = resolve_workdir(remaining)

        action = ''
        detail = ''
        comment = ''
        review_by = ''
        model = os.environ.get('DELEGATE_ACTIVE_MODEL',
                os.environ.get('CODEX_MODEL', 'unknown'))

        i = 0
        while i < len(remaining):
            if remaining[i] == '--action' and i + 1 < len(remaining):
                action = remaining[i + 1]
                i += 2
            elif remaining[i] == '--detail' and i + 1 < len(remaining):
                detail = remaining[i + 1]
                i += 2
            elif remaining[i] == '--comment' and i + 1 < len(remaining):
                comment = remaining[i + 1]
                i += 2
            elif remaining[i] == '--model' and i + 1 < len(remaining):
                model = remaining[i + 1]
                i += 2
            elif remaining[i] == '--review-by' and i + 1 < len(remaining):
                review_by = remaining[i + 1]
                i += 2
            else:
                i += 1

        if not action:
            print("--action is required.", file=sys.stderr)
            print("Valid: fix, refactor, doc, improve, ack, dismiss, defer", file=sys.stderr)
            sys.exit(1)
        if not detail:
            print("--detail is required. Describe what you did or why.", file=sys.stderr)
            sys.exit(1)

        cmd_graduate(workdir, finding_id, action, detail, comment, model, review_by)

    else:
        print(f"Unknown subcommand: {subcmd}", file=sys.stderr)
        print("Valid: pending, deferred, graduate, summary", file=sys.stderr)
        sys.exit(1)


if __name__ == '__main__':
    main()
