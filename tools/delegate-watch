#!/usr/bin/env python3
"""
delegate-watch — live streaming log of delegation progress.

Usage:
  delegate-watch [workdir]                    Watch the latest session
  delegate-watch [workdir] --session <file>   Watch a specific session
"""
import sys
import os
import json
import re
import time
from pathlib import Path
from datetime import datetime

try:
    from rich.console import Console
    from rich.text import Text
    HAS_RICH = True
except ImportError:
    HAS_RICH = False


def find_latest_session(workdir: str) -> str:
    session_dir = Path(workdir) / '.delegate' / 'sessions'
    if not session_dir.exists():
        return ''
    files = sorted(session_dir.glob('*.jsonl'), key=lambda f: f.stat().st_mtime, reverse=True)
    return str(files[0]) if files else ''


def read_active_model(workdir: str) -> str:
    active = Path(workdir) / '.delegate' / 'active-model'
    if active.exists():
        try:
            return active.read_text().strip()
        except Exception:
            pass
    return ''


def format_event(item: dict, cmd: str = '') -> tuple:
    """Returns (type, display_text) for an event item."""
    item_type = item.get('type', '')

    if item_type == 'reasoning':
        text = item.get('text', '').strip()
        if text:
            return ('thinking', text[:300])
        return ('skip', '')

    if item_type in ('message', 'text', 'agent_message'):
        content = item.get('content', '') or item.get('text', '') or ''
        if isinstance(content, list):
            content = ' '.join(c.get('text', '') for c in content if isinstance(c, dict))
        text = str(content).strip()
        if text:
            return ('message', text[:500])
        return ('skip', '')

    if item_type in ('tool_call', 'function_call', 'computer_call', 'command_execution'):
        name = item.get('name', '')
        args = item.get('arguments', '') or item.get('input', '') or ''
        command = item.get('command', '')
        if isinstance(args, dict):
            args = json.dumps(args)

        if command:
            inner = re.search(r"'(.+)'", command)
            display = inner.group(1) if inner else command
            # Classify
            real_files = re.findall(r'[\w/.-]+\.(?:py|js|ts|tsx|jsx|go|rs|rb|sh|yaml|yml|json|md|toml)\b', display)
            if any(r in display for r in ['cat ', 'head ', 'tail ', 'sed -n']):
                target = os.path.basename(real_files[0]) if real_files else display[:60]
                return ('read', f"read {target}")
            elif any(w in display for w in ['python3 -c', 'tee ', '> ', 'cp ']):
                target = os.path.basename(real_files[-1]) if real_files else display[:60]
                return ('write', f"write {target}")
            elif 'grep' in display or 'rg ' in display:
                return ('tool', f"search {display[:70]}")
            elif 'py_compile' in display or 'pytest' in display:
                return ('tool', f"test {display[:70]}")
            else:
                return ('tool', display[:80])
        elif 'write' in name.lower() or 'edit' in name.lower():
            try:
                a = json.loads(args) if isinstance(args, str) else args
                fp = a.get('path', '') or a.get('file_path', '')
            except Exception:
                fp = ''
            return ('write', f"edit {os.path.basename(fp) if fp else args[:60]}")
        elif 'read' in name.lower():
            return ('read', f"read {args[:60]}")
        else:
            return ('tool', f"{name} {args[:50]}")

    if item_type == 'tool_call_output':
        output = str(item.get('output', ''))
        if 'error' in output.lower() or 'failed' in output.lower():
            first_line = output.split('\n')[0][:120]
            return ('error', f"ERROR: {first_line}")
        return ('skip', '')

    return ('skip', '')


def stream_rich(workdir: str, session_file: str):
    console = Console()
    project = os.path.basename(os.path.abspath(workdir))
    processed = 0
    current_session = session_file
    consecutive_tools = 0
    tool_buffer = []

    def flush_tools():
        nonlocal consecutive_tools, tool_buffer
        if not tool_buffer:
            return
        if len(tool_buffer) <= 3:
            for t in tool_buffer:
                console.print(Text(f"  {t}", style="dim"))
        else:
            for t in tool_buffer[:2]:
                console.print(Text(f"  {t}", style="dim"))
            console.print(Text(f"  ... +{len(tool_buffer) - 2} more tool calls", style="dim italic"))
        tool_buffer.clear()
        consecutive_tools = 0

    # Header
    model = read_active_model(workdir) or 'unknown'
    console.print(Text(f"━━━ {project} ━━━ Model: {model} ━━━", style="bold cyan"))
    console.print(Text(f"Session: {os.path.basename(session_file)}", style="dim"))
    console.print()

    try:
        while True:
            # Auto-follow new sessions
            latest = find_latest_session(workdir)
            if latest and latest != current_session:
                flush_tools()
                current_session = latest
                processed = 0
                model = read_active_model(workdir) or model
                console.print()
                console.print(Text(f"━━━ Step changed ━━━ Model: {model} ━━━", style="bold yellow"))
                console.print(Text(f"Session: {os.path.basename(current_session)}", style="dim"))
                console.print()

            # Read new events
            try:
                with open(current_session) as f:
                    lines = f.readlines()
            except Exception:
                time.sleep(1)
                continue

            new_lines = lines[processed:]
            if not new_lines:
                # Check for model change even without new events
                new_model = read_active_model(workdir) or ''
                if new_model and new_model != model:
                    flush_tools()
                    model = new_model
                    console.print()
                    console.print(Text(f"━━━ Model: {model} ━━━", style="bold yellow"))
                    console.print()
                time.sleep(1)
                continue

            for line in new_lines:
                line = line.strip()
                if not line:
                    continue
                try:
                    msg = json.loads(line)
                except json.JSONDecodeError:
                    continue

                item = msg.get('item', {}) or {}
                event_type = msg.get('type', '')

                # Skip non-item events
                if event_type in ('thread.started', 'turn.started', 'turn.completed',
                                  'item.started', 'exec.completed'):
                    continue

                etype, text = format_event(item, item.get('command', ''))

                if etype == 'skip':
                    continue

                if etype == 'message':
                    flush_tools()
                    console.print(Text(f"\n{text}\n", style="white"))

                elif etype == 'thinking':
                    flush_tools()
                    console.print(Text(f"  💭 {text}", style="dim italic"))

                elif etype in ('tool', 'read', 'write'):
                    style_map = {'read': 'blue', 'write': 'green', 'tool': 'yellow'}
                    tool_buffer.append(f"[{etype}] {text}")
                    consecutive_tools += 1
                    # Flush periodically so user sees progress
                    if consecutive_tools >= 6:
                        flush_tools()

                elif etype == 'error':
                    flush_tools()
                    console.print(Text(f"  ⚠ {text}", style="bold red"))

            processed = len(lines)
            time.sleep(0.5)

    except KeyboardInterrupt:
        flush_tools()
        console.print(Text("\nStopped.", style="dim"))


def stream_plain(workdir: str, session_file: str):
    project = os.path.basename(os.path.abspath(workdir))
    processed = 0
    current_session = session_file
    tool_buffer = []

    def flush_tools():
        nonlocal tool_buffer
        if not tool_buffer:
            return
        if len(tool_buffer) <= 3:
            for t in tool_buffer:
                print(f"  {t}")
        else:
            for t in tool_buffer[:2]:
                print(f"  {t}")
            print(f"  ... +{len(tool_buffer) - 2} more tool calls")
        tool_buffer.clear()

    model = read_active_model(workdir) or 'unknown'
    print(f"=== {project} === Model: {model} ===")
    print(f"Session: {os.path.basename(session_file)}\n")

    try:
        while True:
            latest = find_latest_session(workdir)
            if latest and latest != current_session:
                flush_tools()
                current_session = latest
                processed = 0
                model = read_active_model(workdir) or model
                print(f"\n=== Step changed === Model: {model} ===")
                print(f"Session: {os.path.basename(current_session)}\n")

            try:
                with open(current_session) as f:
                    lines = f.readlines()
            except Exception:
                time.sleep(1)
                continue

            new_lines = lines[processed:]
            if not new_lines:
                time.sleep(1)
                continue

            for line in new_lines:
                line = line.strip()
                if not line:
                    continue
                try:
                    msg = json.loads(line)
                except json.JSONDecodeError:
                    continue

                item = msg.get('item', {}) or {}
                event_type = msg.get('type', '')

                if event_type in ('thread.started', 'turn.started', 'turn.completed',
                                  'item.started', 'exec.completed'):
                    continue

                etype, text = format_event(item)

                if etype == 'skip':
                    continue
                elif etype == 'message':
                    flush_tools()
                    print(f"\n{text}\n")
                elif etype == 'thinking':
                    flush_tools()
                    print(f"  [thinking] {text}")
                elif etype in ('tool', 'read', 'write'):
                    tool_buffer.append(f"[{etype}] {text}")
                    if len(tool_buffer) >= 6:
                        flush_tools()
                elif etype == 'error':
                    flush_tools()
                    print(f"  ERROR: {text}")

            processed = len(lines)
            time.sleep(0.5)

    except KeyboardInterrupt:
        flush_tools()
        print("\nStopped.")


def main():
    args = sys.argv[1:]
    workdir = args[0] if args and not args[0].startswith('--') else os.getcwd()
    session_file = ''

    i = 1 if args and not args[0].startswith('--') else 0
    while i < len(args):
        if args[i] == '--session' and i + 1 < len(args):
            session_file = args[i + 1]
            i += 2
        else:
            i += 1

    if not session_file:
        session_file = find_latest_session(workdir)

    if not session_file:
        print("No session files found in .delegate/sessions/", file=sys.stderr)
        print("Run a delegation first, then watch it.", file=sys.stderr)
        sys.exit(1)

    if HAS_RICH:
        stream_rich(workdir, session_file)
    else:
        stream_plain(workdir, session_file)


if __name__ == '__main__':
    main()
