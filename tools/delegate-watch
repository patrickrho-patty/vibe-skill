#!/usr/bin/env python3
"""
delegate-watch — live TUI showing delegation progress with fixed header and scrollable log.

Usage:
  delegate-watch [workdir]                    Watch the latest session
  delegate-watch [workdir] --session <file>   Watch a specific session
"""
import sys
import os
import json
import re
import time
from pathlib import Path
from datetime import datetime

# ── Event formatting ─────────────────────────────────────────────────────────

def find_latest_session(workdir: str) -> str:
    session_dir = Path(workdir) / '.delegate' / 'sessions'
    if not session_dir.exists():
        return ''
    files = sorted(session_dir.glob('*.jsonl'), key=lambda f: f.stat().st_mtime, reverse=True)
    return str(files[0]) if files else ''


def read_active_model(workdir: str) -> str:
    active = Path(workdir) / '.delegate' / 'active-model'
    if active.exists():
        try:
            return active.read_text().strip()
        except Exception:
            pass
    runs = Path(workdir) / '.delegate' / 'runs.jsonl'
    if runs.exists():
        try:
            lines = runs.read_text().strip().splitlines()
            if lines:
                last = json.loads(lines[-1])
                m = last.get('model', '')
                if m:
                    return m
        except Exception:
            pass
    return 'unknown'


def format_event(item: dict) -> tuple:
    item_type = item.get('type', '')

    if item_type == 'reasoning':
        text = item.get('text', '').strip()
        return ('thinking', text[:300]) if text else ('skip', '')

    if item_type in ('message', 'text', 'agent_message'):
        content = item.get('content', '') or item.get('text', '') or ''
        if isinstance(content, list):
            content = ' '.join(c.get('text', '') for c in content if isinstance(c, dict))
        text = str(content).strip()
        return ('message', text[:500]) if text else ('skip', '')

    if item_type in ('tool_call', 'function_call', 'computer_call', 'command_execution'):
        name = item.get('name', '')
        args = item.get('arguments', '') or item.get('input', '') or ''
        command = item.get('command', '')
        if isinstance(args, dict):
            args = json.dumps(args)

        if command:
            inner = re.search(r"'(.+)'", command)
            display = inner.group(1) if inner else command
            real_files = re.findall(r'[\w/.-]+\.(?:py|js|ts|tsx|jsx|go|rs|rb|sh|yaml|yml|json|md|toml)\b', display)
            if any(r in display for r in ['cat ', 'head ', 'tail ', 'sed -n']):
                target = os.path.basename(real_files[0]) if real_files else display[:60]
                return ('read', f"read {target}")
            elif any(w in display for w in ['python3 -c', 'tee ', '> ', 'cp ']):
                target = os.path.basename(real_files[-1]) if real_files else display[:60]
                return ('write', f"write {target}")
            elif 'grep' in display or 'rg ' in display:
                return ('tool', f"search {display[:70]}")
            elif 'py_compile' in display or 'pytest' in display:
                return ('tool', f"test {display[:70]}")
            else:
                return ('tool', display[:80])
        elif 'write' in name.lower() or 'edit' in name.lower():
            try:
                a = json.loads(args) if isinstance(args, str) else args
                fp = a.get('path', '') or a.get('file_path', '')
            except Exception:
                fp = ''
            return ('write', f"edit {os.path.basename(fp) if fp else args[:60]}")
        elif 'read' in name.lower():
            return ('read', f"read {args[:60]}")
        else:
            return ('tool', f"{name} {args[:50]}")

    if item_type == 'tool_call_output':
        output = str(item.get('output', ''))
        if 'error' in output.lower() or 'failed' in output.lower():
            return ('error', output.split('\n')[0][:120])
        return ('skip', '')

    return ('skip', '')


# ── Textual TUI ──────────────────────────────────────────────────────────────

def run_textual_app(workdir: str, session_file: str):
    from textual.app import App, ComposeResult
    from textual.widgets import Header, Footer, Static, RichLog
    from textual.containers import VerticalScroll
    from textual import work

    project = os.path.basename(os.path.abspath(workdir))

    class DelegateWatch(App):
        CSS = """
        #status-bar {
            dock: top;
            height: 2;
            background: $primary-background;
            color: $text;
            padding: 0 1;
        }
        #log {
            height: 1fr;
        }
        """
        BINDINGS = [("q", "quit", "Quit"), ("c", "clear_log", "Clear")]

        def __init__(self):
            super().__init__()
            self.session_file = session_file
            self.processed = 0
            self.events_count = 0
            self.tools_count = 0
            self.warns_count = 0
            self.model = read_active_model(workdir) or 'unknown'
            self.tool_buffer = []

        def compose(self) -> ComposeResult:
            yield Static(self._header_text(), id="status-bar")
            yield RichLog(highlight=True, markup=True, id="log")
            yield Footer()

        def _is_running(self) -> bool:
            pid_file = Path(workdir) / '.delegate' / 'delegate.pid'
            if pid_file.exists():
                try:
                    pid = int(pid_file.read_text().strip())
                    os.kill(pid, 0)
                    return True
                except (ValueError, ProcessLookupError):
                    return False
                except PermissionError:
                    return True
            return False

        def _header_text(self) -> str:
            sf = os.path.basename(self.session_file)
            running = self._is_running()
            status = "[bold green]● Running[/]" if running else "[dim]○ Idle[/]"
            model_part = f"  Model: [cyan]{self.model}[/]" if running else ""
            return (f"[bold]{project}[/]  {status}{model_part}  "
                    f"Events: {self.events_count}  Tools: {self.tools_count}  "
                    f"Warns: {self.warns_count}  [dim]{sf}[/]")

        def on_mount(self) -> None:
            self.set_interval(0.5, self.poll_events)

        def _flush_tools(self):
            log = self.query_one("#log", RichLog)
            if not self.tool_buffer:
                return
            if len(self.tool_buffer) <= 3:
                for t in self.tool_buffer:
                    log.write(f"  [dim]{t}[/]")
            else:
                for t in self.tool_buffer[:2]:
                    log.write(f"  [dim]{t}[/]")
                log.write(f"  [dim italic]... +{len(self.tool_buffer) - 2} more tool calls[/]")
            self.tool_buffer.clear()

        def poll_events(self) -> None:
            # Auto-follow latest session
            latest = find_latest_session(workdir)
            if latest and latest != self.session_file:
                self._flush_tools()
                self.session_file = latest
                self.processed = 0
                new_model = read_active_model(workdir)
                if new_model:
                    self.model = new_model
                log = self.query_one("#log", RichLog)
                log.write("")
                log.write(f"[bold yellow]━━━ Step changed ━━━ Model: {self.model} ━━━[/]")
                log.write("")

            # Check model change
            new_model = read_active_model(workdir)
            if new_model and new_model != self.model:
                self.model = new_model

            # Read new events
            try:
                with open(self.session_file) as f:
                    lines = f.readlines()
            except Exception:
                self.query_one("#status-bar", Static).update(self._header_text())
                return

            new_lines = lines[self.processed:]
            if not new_lines:
                self.query_one("#status-bar", Static).update(self._header_text())
                return

            log = self.query_one("#log", RichLog)

            for line in new_lines:
                line = line.strip()
                if not line:
                    continue
                try:
                    msg = json.loads(line)
                except json.JSONDecodeError:
                    continue

                self.events_count += 1
                item = msg.get('item', {}) or {}
                event_type = msg.get('type', '')

                if event_type in ('thread.started', 'turn.started', 'turn.completed',
                                  'item.started', 'exec.completed'):
                    continue

                etype, etext = format_event(item)

                if etype == 'skip':
                    continue
                elif etype == 'message':
                    self._flush_tools()
                    log.write("")
                    log.write(etext)
                    log.write("")
                elif etype == 'thinking':
                    self._flush_tools()
                    log.write(f"  [dim italic]💭 {etext}[/]")
                elif etype in ('tool', 'read', 'write'):
                    self.tools_count += 1
                    self.tool_buffer.append(f"[{etype}] {etext}")
                    if len(self.tool_buffer) >= 6:
                        self._flush_tools()
                elif etype == 'error':
                    self._flush_tools()
                    self.warns_count += 1
                    log.write(f"  [bold red]⚠ {etext}[/]")

            self._flush_tools()
            self.processed = len(lines)
            self.query_one("#status-bar", Static).update(self._header_text())

        def action_clear_log(self) -> None:
            self.query_one("#log", RichLog).clear()

    DelegateWatch().run()


# ── Plain text fallback ──────────────────────────────────────────────────────

def stream_plain(workdir: str, session_file: str):
    project = os.path.basename(os.path.abspath(workdir))
    processed = 0
    current_session = session_file
    tool_buffer = []
    lines_since_header = 0

    def flush_tools():
        nonlocal tool_buffer
        if not tool_buffer:
            return
        if len(tool_buffer) <= 3:
            for t in tool_buffer:
                print(f"  {t}")
        else:
            for t in tool_buffer[:2]:
                print(f"  {t}")
            print(f"  ... +{len(tool_buffer) - 2} more tool calls")
        tool_buffer.clear()

    def print_header():
        nonlocal lines_since_header
        model = read_active_model(workdir) or 'unknown'
        sf = os.path.basename(current_session)
        print(f"\n━━━ {project} ━━━ Model: {model} ━━━ {sf} ━━━")
        lines_since_header = 0

    print_header()

    try:
        while True:
            latest = find_latest_session(workdir)
            if latest and latest != current_session:
                flush_tools()
                current_session = latest
                processed = 0
                print(f"\n━━━ Step changed ━━━")
                print_header()

            try:
                with open(current_session) as f:
                    lines = f.readlines()
            except Exception:
                time.sleep(1)
                continue

            new_lines = lines[processed:]
            if not new_lines:
                time.sleep(1)
                continue

            for line in new_lines:
                line = line.strip()
                if not line:
                    continue
                try:
                    msg = json.loads(line)
                except json.JSONDecodeError:
                    continue

                item = msg.get('item', {}) or {}
                event_type = msg.get('type', '')
                if event_type in ('thread.started', 'turn.started', 'turn.completed',
                                  'item.started', 'exec.completed'):
                    continue

                etype, etext = format_event(item)
                if etype == 'skip':
                    continue
                elif etype == 'message':
                    flush_tools()
                    print(f"\n{etext}\n")
                    lines_since_header += 3
                elif etype == 'thinking':
                    flush_tools()
                    print(f"  [thinking] {etext}")
                    lines_since_header += 1
                elif etype in ('tool', 'read', 'write'):
                    tool_buffer.append(f"[{etype}] {etext}")
                    if len(tool_buffer) >= 6:
                        flush_tools()
                elif etype == 'error':
                    flush_tools()
                    print(f"  ERROR: {etext}")
                    lines_since_header += 1

                if lines_since_header >= 25:
                    print_header()

            flush_tools()
            processed = len(lines)
            time.sleep(0.5)

    except KeyboardInterrupt:
        flush_tools()
        print("\nStopped.")


# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]
    workdir = args[0] if args and not args[0].startswith('--') else os.getcwd()
    session_file = ''

    i = 1 if args and not args[0].startswith('--') else 0
    while i < len(args):
        if args[i] == '--session' and i + 1 < len(args):
            session_file = args[i + 1]
            i += 2
        else:
            i += 1

    if not session_file:
        session_file = find_latest_session(workdir)

    if not session_file:
        print("No session files found in .delegate/sessions/", file=sys.stderr)
        print("Run a delegation first, then watch it.", file=sys.stderr)
        sys.exit(1)

    try:
        import textual
        run_textual_app(workdir, session_file)
    except ImportError:
        try:
            from rich.console import Console
            stream_plain(workdir, session_file)
        except ImportError:
            stream_plain(workdir, session_file)


if __name__ == '__main__':
    main()
