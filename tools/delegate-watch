#!/usr/bin/env python3
"""
delegate-watch — live TUI showing current delegation progress.

Usage:
  delegate-watch <workdir>                    Watch the latest session
  delegate-watch <workdir> --session <file>   Watch a specific session
"""
import sys
import os
import json
import time
from pathlib import Path
from datetime import datetime

try:
    from rich.console import Console
    from rich.panel import Panel
    from rich.table import Table
    from rich.live import Live
    from rich.text import Text
    from rich import box
    HAS_RICH = True
except ImportError:
    HAS_RICH = False


def find_latest_session(workdir: str) -> str:
    session_dir = Path(workdir) / '.delegate' / 'sessions'
    if not session_dir.exists():
        return ''
    files = sorted(session_dir.glob('*.jsonl'), key=lambda f: f.stat().st_mtime, reverse=True)
    return str(files[0]) if files else ''


def read_model(workdir: str) -> str:
    # 1. Active model file (written by delegate at start of each run — always current)
    active = Path(workdir) / '.delegate' / 'active-model'
    if active.exists():
        try:
            val = active.read_text().strip()
            if val:
                return val
        except Exception:
            pass
    # 2. Fall back to last run's model in runs.jsonl
    runs = Path(workdir) / '.delegate' / 'runs.jsonl'
    if runs.exists():
        try:
            lines = runs.read_text().strip().splitlines()
            if lines:
                last = json.loads(lines[-1])
                m = last.get('model', '')
                if m:
                    return m
        except Exception:
            pass
    return 'unknown'


def parse_session(session_file: str, workdir: str = '') -> dict:
    events = []
    tool_calls = 0
    warns = 0
    # Read model from the LATEST runs.jsonl entry (updates per step)
    model = read_model(workdir) if workdir else 'unknown'
    messages = []
    files_touched = set()
    reads = []
    edits = []

    try:
        with open(session_file) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    msg = json.loads(line)
                except json.JSONDecodeError:
                    continue

                events.append(msg)
                event_type = msg.get('type', '')
                item = msg.get('item', {}) or {}
                item_type = item.get('type', '')

                if msg.get('model'):
                    model = msg['model']
                if isinstance(msg.get('session'), dict):
                    m = msg['session'].get('model', '')
                    if m:
                        model = m

                if item_type in ('tool_call', 'function_call', 'computer_call', 'command_execution'):
                    tool_calls += 1
                    name = item.get('name', '')
                    args = item.get('arguments', '') or item.get('input', '') or ''
                    cmd = item.get('command', '')
                    if isinstance(args, dict):
                        args = json.dumps(args)

                    if cmd:
                        # Codex command_execution: extract the inner command
                        # Format: /bin/zsh -lc 'actual command here'
                        import re
                        inner = re.search(r"'(.+)'", cmd)
                        display_cmd = inner.group(1) if inner else cmd
                        display_short = display_cmd[:80]

                        # Extract real file paths (must end in .py, .js, .ts, etc.)
                        real_files = re.findall(r'[\w/.-]+\.(?:py|js|ts|tsx|jsx|go|rs|rb|sh|yaml|yml|json|md|toml|cfg)\b', display_cmd)
                        for fp in real_files:
                            files_touched.add(os.path.basename(fp))

                        # Classify the command
                        if any(r in display_cmd for r in ['cat ', 'head ', 'tail ', 'less ', 'sed -n']):
                            target = os.path.basename(real_files[0]) if real_files else display_short
                            reads.append(f"[read] {target}")
                        elif any(w in display_cmd for w in ['python3 -c', 'tee ', '> ', 'cp ', 'mv ']):
                            target = os.path.basename(real_files[-1]) if real_files else display_short
                            edits.append(f"[write] {target}")
                        elif 'grep' in display_cmd:
                            edits.append(f"[grep] {display_short}")
                        else:
                            edits.append(f"[cmd]  {display_short}")

                    elif 'write' in name.lower() or 'edit' in name.lower():
                        try:
                            a = json.loads(args) if isinstance(args, str) else args
                            fp = a.get('path', '') or a.get('file_path', '')
                        except Exception:
                            fp = ''
                        if fp:
                            files_touched.add(os.path.basename(fp))
                        edits.append(f"[edit] {fp or args[:60]}")
                    elif 'read' in name.lower():
                        reads.append(f"[read] {str(args)[:60]}")
                    elif 'bash' in name.lower() or 'shell' in name.lower():
                        edits.append(f"[cmd]  {str(args)[:60]}")
                    else:
                        edits.append(f"[tool] {name}: {str(args)[:50]}")

                elif item_type == 'tool_call_output':
                    output = str(item.get('output', ''))
                    if 'error' in output.lower() or 'failed' in output.lower():
                        warns += 1

                elif item_type in ('message', 'text', 'agent_message'):
                    content = item.get('content', '') or item.get('text', '') or ''
                    if isinstance(content, list):
                        content = ' '.join(c.get('text', '') for c in content if isinstance(c, dict))
                    if str(content).strip():
                        messages.append(str(content).strip()[:200])

                elif item_type == 'reasoning':
                    text = item.get('text', '')
                    if text:
                        messages.append(f"[thinking] {text.strip()[:200]}")

    except Exception:
        pass

    return {
        'events': len(events),
        'tool_calls': tool_calls,
        'warns': warns,
        'model': model,
        'messages': messages[-8:],
        'files_touched': files_touched,
        'reads': reads[-5:],
        'edits': edits[-5:],
        'activity': (reads + edits)[-6:],
    }


def plain_watch(workdir: str, session_file: str):
    print(f"Watching: {session_file}")
    print(f"Press Ctrl+C to stop\n")

    current_session = session_file
    last_size = 0
    while True:
        # Auto-follow latest session
        latest = find_latest_session(workdir)
        if latest and latest != current_session:
            current_session = latest
            last_size = 0

        try:
            current_size = os.path.getsize(current_session)
        except OSError:
            current_size = 0

        if current_size != last_size:
            last_size = current_size
            state = parse_session(current_session, workdir)
            os.system('clear')
            project = os.path.basename(os.path.abspath(workdir))
            print(f"=== {project} — DELEGATION LIVE ({datetime.now().strftime('%H:%M:%S')}) ===")
            print(f"Session: {os.path.basename(current_session)}")
            print(f"Model  : {state['model']}")
            print(f"Events : {state['events']}  Tools: {state['tool_calls']}  Warns: {state['warns']}")
            print(f"Files  : {', '.join(state['files_touched']) or '(none yet)'}")
            print(f"\n--- Activity ---")
            for line in state['activity']:
                print(f"  {line}")
            if state['messages']:
                print(f"\n--- Recent messages ---")
                for msg in state['messages']:
                    print(f"  {msg}")
            print(f"\n(watching... Ctrl+C to stop)")

        time.sleep(1)


def rich_watch(workdir: str, session_file: str):
    console = Console()
    current_session = [session_file]  # mutable ref for closure

    def build_display():
        # Auto-follow latest session (new step = new session file)
        latest = find_latest_session(workdir)
        if latest and latest != current_session[0]:
            current_session[0] = latest

        sf = current_session[0]
        try:
            current_size = os.path.getsize(sf)
        except OSError:
            current_size = 0

        state = parse_session(sf, workdir)
        now = datetime.now().strftime('%H:%M:%S')

        # Show session filename as step indicator
        sf_name = os.path.basename(sf)

        project = os.path.basename(os.path.abspath(workdir))
        header = f"[bold cyan]{project}[/]  [bold]Model:[/] {state['model']}  [bold]Events:[/] {state['events']}  [bold]Tools:[/] {state['tool_calls']}  [bold]Warns:[/] {state['warns']}  [dim]{sf_name}[/dim]"
        files_str = ', '.join(state['files_touched']) or '(none yet)'

        activity_table = Table(box=box.SIMPLE, show_header=False, padding=(0, 1))
        activity_table.add_column("Activity", style="dim")
        for line in state['activity']:
            style = ""
            if '[edit]' in line:
                style = "green"
            elif '[read]' in line:
                style = "blue"
            elif '[cmd]' in line:
                style = "yellow"
            elif 'WARN' in line:
                style = "red"
            activity_table.add_row(Text(line, style=style))

        msg_lines = state['messages'] if state['messages'] else ['(waiting...)']
        msg_text = '\n'.join(f'  {m}' for m in msg_lines)

        output = []
        output.append(Panel(header, title=f"DELEGATION LIVE — {now}", border_style="cyan"))
        output.append(f"[bold]Files:[/] {files_str}\n")
        output.append(activity_table)
        output.append(f"\n[bold]Recent messages:[/]\n{msg_text}")

        console.clear()
        for item in output:
            if isinstance(item, str):
                console.print(item)
            else:
                console.print(item)

    try:
        while True:
            build_display()
            time.sleep(1)
    except KeyboardInterrupt:
        console.print("\n[dim]Stopped watching.[/dim]")


def main():
    args = sys.argv[1:]

    workdir = args[0] if args and not args[0].startswith('--') else os.getcwd()
    session_file = ''

    i = 1
    while i < len(args):
        if args[i] == '--session' and i + 1 < len(args):
            session_file = args[i + 1]
            i += 2
        else:
            i += 1

    if not session_file:
        session_file = find_latest_session(workdir)

    if not session_file:
        print("No session files found in .delegate/sessions/", file=sys.stderr)
        sys.exit(1)

    print(f"Watching: {session_file}")
    print("Press Ctrl+C to stop\n")

    if HAS_RICH:
        rich_watch(workdir, session_file)
    else:
        plain_watch(workdir, session_file)


if __name__ == '__main__':
    main()
