#!/usr/bin/env bash
# adapters/opencode — OpenCode adapter for tools/delegate
# Usage: adapters/opencode <workdir> <prompt_file> <max_turns> <agent> <timeout_secs> <stats_file>
#
# OpenCode CLI interface (opencode-ai/opencode):
#   opencode run "prompt"                   — run prompt non-interactively
#   opencode run --format json "prompt"     — JSON event stream to stdout
#   opencode run --dir /path "prompt"       — set working directory
#   --dangerously-skip-permissions          — auto-approve tool use
#   No TTY required

WORKDIR="${1:?Usage: adapters/opencode <workdir> <prompt_file> <max_turns> <agent> <timeout_secs> <stats_file>}"
PROMPT_FILE="${2:?Prompt file required}"
MAX_TURNS="${3:-10}"
AGENT="${4:-}"
TIMEOUT_SECS="${5:-180}"
STATS_FILE="${6:?Stats file required}"

if ! command -v opencode &>/dev/null; then
  echo "[opencode] ERROR: 'opencode' CLI not found. Install: https://opencode.ai/docs/" >&2
  python3 -c "
import json, os
sf = os.environ.get('DELEGATE_STATS_FILE', '')
if sf:
    with open(sf, 'w') as f:
        json.dump({'tool_calls': 0, 'warn_count': 0, 'tokens_total': 0, 'cost_usd': 0, 'model': 'opencode-unknown'}, f)
"
  exit 1
fi

PROMPT_CONTENT=$(cat "$PROMPT_FILE")

export DELEGATE_STATS_FILE="$STATS_FILE"

OC_STDERR=$(mktemp /tmp/opencode-stderr-XXXXXX)

timeout "$TIMEOUT_SECS" opencode run \
  --format json \
  --dir "$WORKDIR" \
  --dangerously-skip-permissions \
  "$PROMPT_CONTENT" 2>"$OC_STDERR" | python3 -c "
import sys, json, re, os, datetime

tools_called = 0
warn_count = 0
sr_fails = 0
model_name = 'opencode-unknown'
tokens_in = 0
tokens_out = 0

# Session recording
workdir = os.environ.get('DELEGATE_WORKDIR', os.getcwd())
session_dir = os.path.join(workdir, '.delegate', 'sessions')
os.makedirs(session_dir, exist_ok=True)
session_file = os.path.join(
    session_dir,
    datetime.datetime.utcnow().strftime('%Y-%m-%dT%H-%M-%SZ') + '-opencode.jsonl'
)
sf = open(session_file, 'w')

for raw in sys.stdin:
    line = raw.strip()
    if not line:
        continue
    try:
        msg = json.loads(line)
    except json.JSONDecodeError:
        continue

    sf.write(json.dumps(msg) + '\n')

    event_type = msg.get('type', '') or msg.get('event', '') or ''
    content = msg.get('content', '') or msg.get('text', '') or msg.get('data', '') or ''
    if isinstance(content, dict):
        content = json.dumps(content)

    # Extract model name
    if msg.get('model'):
        model_name = msg['model']

    # Detect tool calls
    if event_type in ('tool_call', 'tool_use', 'tool', 'function_call'):
        tools_called += 1
        tool_name = msg.get('name', '') or msg.get('tool', '') or ''
        if 'write' in tool_name.lower() or 'edit' in tool_name.lower() or 'file' in tool_name.lower():
            filepath = msg.get('path', '') or msg.get('file_path', '') or ''
            print(f'  [tool]  file: {filepath or str(content)[:80]}', flush=True)
        elif 'search_replace' in tool_name.lower() or 'patch' in tool_name.lower():
            status = 'FAIL' if 'failed' in str(content).lower() else 'OK'
            if status == 'FAIL':
                sr_fails += 1
            print(f'  [tool]  search_replace [{status}]', flush=True)
        elif 'read' in tool_name.lower():
            print(f'  [read]  {str(content)[:80]}', flush=True)
        elif 'bash' in tool_name.lower() or 'shell' in tool_name.lower() or 'command' in tool_name.lower():
            print(f'  [tool]  command: {str(content)[:100]}', flush=True)
        else:
            print(f'  [tool]  {tool_name}: {str(content)[:80]}', flush=True)

    elif event_type in ('tool_result', 'tool_output'):
        first_line = str(content).split('\n')[0][:120]
        if 'error' in first_line.lower() or 'failed' in first_line.lower():
            warn_count += 1
            print(f'  [WARN]  {first_line}', flush=True)

    elif event_type in ('assistant', 'text', 'message', 'response'):
        text = str(content).strip()
        if text:
            print(f'  [opencode] {text[:400]}', flush=True)

    elif event_type in ('usage', 'stats', 'done', 'complete', 'summary'):
        usage = msg.get('usage', {}) or msg
        if isinstance(usage, dict):
            ti = usage.get('input_tokens', 0) or usage.get('prompt_tokens', 0)
            to = usage.get('output_tokens', 0) or usage.get('completion_tokens', 0)
            if ti:
                tokens_in = ti
            if to:
                tokens_out = to
            m = usage.get('model', '')
            if m:
                model_name = m

sf.close()
print(f'Tool calls: {tools_called}  |  warns: {warn_count}  |  sr_fails: {sr_fails}')
print(f'Session recorded: {session_file}')

# Compute cost estimate (OpenCode uses various providers; default estimate)
tokens_total = tokens_in + tokens_out
input_price, output_price = 3.0, 15.0  # Conservative: Claude Sonnet rates as fallback
cost_usd = (tokens_in * input_price + tokens_out * output_price) / 1_000_000

_sf = os.environ.get('DELEGATE_STATS_FILE', '')
if _sf:
    try:
        stats = {
            'tool_calls': tools_called,
            'warn_count': warn_count,
            'search_replace_fails': sr_fails,
            'tokens_in': tokens_in,
            'tokens_out': tokens_out,
            'tokens_total': tokens_total,
            'cost_usd': round(cost_usd, 6),
            'model': model_name,
            'session_file': session_file,
        }
        with open(_sf, 'w') as _f:
            json.dump(stats, _f)
    except Exception:
        pass
"
OC_EXIT=${PIPESTATUS[0]}

# Surface stderr on failure
if [ "$OC_EXIT" -ne 0 ] && [ -s "$OC_STDERR" ]; then
  echo "  [opencode-stderr] $(head -5 "$OC_STDERR")"
fi
rm -f "$OC_STDERR"

exit $OC_EXIT
