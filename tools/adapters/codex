#!/usr/bin/env bash
# adapters/codex — Codex CLI adapter for tools/delegate
# Usage: adapters/codex <workdir> <prompt_file> <max_turns> <agent> <timeout_secs> <stats_file>
#
# Codex CLI interface (openai/codex):
#   codex exec "prompt"                — non-interactive, final message to stdout
#   codex exec --json "prompt"         — JSON lines event stream
#   codex exec -C <dir> "prompt"       — set working directory
#   codex exec -s workspace-write      — allow file edits
#   codex exec -m <model> "prompt"     — use specific model
#   codex exec -p <profile> "prompt"   — use named profile from config.toml
#
# Model override: DELEGATE_ACTIVE_MODEL or CODEX_MODEL env var
#   If the value contains "/" (e.g., "minimax/MiniMax-M2.7"), the part before "/"
#   is used as the profile name: codex exec -p minimax "prompt"
#   Otherwise it's passed as --model: codex exec -m deepseek-chat "prompt"

WORKDIR="${1:?Usage: adapters/codex <workdir> <prompt_file> <max_turns> <agent> <timeout_secs> <stats_file>}"
PROMPT_FILE="${2:?Prompt file required}"
MAX_TURNS="${3:-10}"
AGENT="${4:-}"
TIMEOUT_SECS="${5:-180}"
STATS_FILE="${6:?Stats file required}"

if ! command -v codex &>/dev/null; then
  echo "[codex] ERROR: 'codex' CLI not found. Install: npm i -g @openai/codex" >&2
  python3 -c "
import json, os
sf = os.environ.get('DELEGATE_STATS_FILE', '')
if sf:
    with open(sf, 'w') as f:
        json.dump({'tool_calls': 0, 'warn_count': 0, 'tokens_total': 0, 'cost_usd': 0, 'model': 'codex-unknown'}, f)
"
  exit 1
fi

PROMPT_CONTENT=$(cat "$PROMPT_FILE")

export DELEGATE_STATS_FILE="$STATS_FILE"

# Model/profile override: CODEX_MODEL > DELEGATE_ACTIVE_MODEL
CODEX_MODEL_OVERRIDE="${CODEX_MODEL:-$DELEGATE_ACTIVE_MODEL}"

# Build the codex command
CODEX_CMD=(codex exec --json -C "$WORKDIR" -s workspace-write)

if [ -n "$CODEX_MODEL_OVERRIDE" ]; then
  if [[ "$CODEX_MODEL_OVERRIDE" == */* ]]; then
    # provider/model format → use profile (the part before /)
    PROFILE="${CODEX_MODEL_OVERRIDE%%/*}"
    CODEX_CMD+=(-p "$PROFILE")
  else
    # plain model name → use --model
    CODEX_CMD+=(-m "$CODEX_MODEL_OVERRIDE")
  fi
fi

CODEX_CMD+=("$PROMPT_CONTENT")

CODEX_STDERR=$(mktemp /tmp/codex-stderr-XXXXXX.log)

timeout "$TIMEOUT_SECS" "${CODEX_CMD[@]}" 2>"$CODEX_STDERR" | python3 -c "
import sys, json, re, os, datetime

tools_called = 0
warn_count = 0
sr_fails = 0
model_name = 'codex-unknown'
tokens_in = 0
tokens_out = 0

# Session recording
workdir = os.environ.get('DELEGATE_WORKDIR', os.getcwd())
session_dir = os.path.join(workdir, '.delegate', 'sessions')
os.makedirs(session_dir, exist_ok=True)
session_file = os.path.join(
    session_dir,
    datetime.datetime.utcnow().strftime('%Y-%m-%dT%H-%M-%SZ') + '-codex.jsonl'
)
sf = open(session_file, 'w')

for raw in sys.stdin:
    line = raw.strip()
    if not line:
        continue
    try:
        msg = json.loads(line)
    except json.JSONDecodeError:
        continue

    sf.write(json.dumps(msg) + '\n')

    event_type = msg.get('type', '') or msg.get('event', '') or ''

    # Codex exec --json emits events like:
    #   thread.started, turn.started, item.created, item.completed,
    #   turn.completed, exec.completed

    # Extract model info
    if msg.get('model'):
        model_name = msg['model']
    if 'session' in msg and isinstance(msg.get('session'), dict):
        m = msg['session'].get('model', '')
        if m:
            model_name = m

    # Tool calls (item.created with type=tool_call or function_call)
    item = msg.get('item', {}) or {}
    item_type = item.get('type', '')

    if item_type in ('tool_call', 'function_call', 'computer_call'):
        tools_called += 1
        tool_name = item.get('name', '') or item.get('call_id', '') or ''
        args = item.get('arguments', '') or item.get('input', '') or ''
        if isinstance(args, dict):
            args = json.dumps(args)

        if 'write' in tool_name.lower() or 'edit' in tool_name.lower():
            filepath = ''
            try:
                a = json.loads(args) if isinstance(args, str) else args
                filepath = a.get('path', '') or a.get('file_path', '')
            except Exception:
                pass
            print(f'  [tool]  file: {filepath or str(args)[:80]}', flush=True)
        elif 'read' in tool_name.lower():
            print(f'  [read]  {str(args)[:80]}', flush=True)
        elif 'bash' in tool_name.lower() or 'shell' in tool_name.lower():
            print(f'  [tool]  command: {str(args)[:100]}', flush=True)
        else:
            print(f'  [tool]  {tool_name}: {str(args)[:80]}', flush=True)

    elif item_type == 'tool_call_output':
        output = item.get('output', '') or ''
        first_line = str(output).split('\n')[0][:120]
        if 'error' in first_line.lower() or 'failed' in first_line.lower():
            warn_count += 1
            print(f'  [WARN]  {first_line}', flush=True)

    elif item_type in ('message', 'text', 'agent_message'):
        content = item.get('content', '') or item.get('text', '') or ''
        if isinstance(content, list):
            content = ' '.join(c.get('text', '') for c in content if isinstance(c, dict))
        text = str(content).strip()
        if text:
            print(f'  [codex] {text[:400]}', flush=True)

    # Token usage from turn.completed or exec.completed
    if event_type in ('turn.completed', 'exec.completed'):
        usage = msg.get('usage', {}) or {}
        ti = usage.get('input_tokens', 0) or usage.get('prompt_tokens', 0)
        to_out = usage.get('output_tokens', 0) or usage.get('completion_tokens', 0)
        if ti:
            tokens_in += ti
        if to_out:
            tokens_out += to_out

sf.close()
tokens_total = tokens_in + tokens_out

print(f'Tool calls: {tools_called}  |  warns: {warn_count}  |  sr_fails: {sr_fails}')
if tokens_total > 0:
    print(f'Tokens: {tokens_total:,} (in: {tokens_in:,}, out: {tokens_out:,})')
print(f'Session recorded: {session_file}')

# Compute cost (use model-specific pricing if known, else OpenAI default)
input_price, output_price = 2.0, 8.0  # Default: mid-range estimate
_sf = os.environ.get('DELEGATE_STATS_FILE', '')
if _sf:
    try:
        cost_usd = (tokens_in * input_price + tokens_out * output_price) / 1_000_000
        stats = {
            'tool_calls': tools_called,
            'warn_count': warn_count,
            'search_replace_fails': sr_fails,
            'tokens_in': tokens_in,
            'tokens_out': tokens_out,
            'tokens_total': tokens_total,
            'cost_usd': round(cost_usd, 6),
            'model': model_name,
            'session_file': session_file,
        }
        with open(_sf, 'w') as _f:
            json.dump(stats, _f)
    except Exception:
        pass
"
CODEX_EXIT=${PIPESTATUS[0]}

# Surface stderr on failure
if [ "$CODEX_EXIT" -ne 0 ] && [ -s "$CODEX_STDERR" ]; then
  echo "  [codex-stderr] $(head -5 "$CODEX_STDERR")"
fi
rm -f "$CODEX_STDERR"

exit $CODEX_EXIT
