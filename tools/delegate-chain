#!/usr/bin/env python3
"""
delegate-chain — run multi-step delegation workflows where each step's output feeds the next.

Usage:
  delegate-chain <workdir> <chain-file> <task>

Arguments:
  workdir     Path to the working directory for delegation.
  chain-file  Path to a YAML chain file (see .delegate/chains/).
  task        Task description. Also accepts DELEGATE_CHAIN_TASK env var.

Chain file format (YAML subset):
  name: <chain-name>
  description: <description>
  steps:
    - role: <role>
      agent: <agent-name>
      turns: <max-turns>
      prompt_template: "<prompt with {task} placeholder>"

Exit codes:
  0  All steps completed successfully.
  1  A step failed (printed which step and exit code).
"""

import sys
import os
import re
import subprocess
import time
import atexit
import signal
import shutil
import json


# ── YAML subset parser ─────────────────────────────────────────────────────────

def parse_chain(path):
    """Parse a chain YAML file using simple line-by-line regex parsing (no PyYAML)."""
    with open(path) as f:
        lines = f.readlines()

    chain = {'name': '', 'description': '', 'steps': []}
    current_step = None
    in_steps = False

    for raw in lines:
        line = raw.rstrip()
        stripped = line.strip()

        # Skip comments and blank lines
        if not stripped or stripped.startswith('#'):
            continue

        # Top-level keys
        if re.match(r'^name:\s*', line):
            chain['name'] = re.sub(r'^name:\s*', '', line).strip().strip('"\'')
            continue
        if re.match(r'^description:\s*', line):
            chain['description'] = re.sub(r'^description:\s*', '', line).strip().strip('"\'')
            continue

        # steps: section header
        if re.match(r'^steps:\s*$', line):
            in_steps = True
            continue

        if not in_steps:
            continue

        # New step item (starts with "  - role:")
        m = re.match(r'^\s+-\s+role:\s*(.+)$', line)
        if m:
            if current_step is not None:
                # Clean up internal parser flags before appending
                for _flag in ('_collecting_prompt', '_in_parallel', '_parallel_section'):
                    current_step.pop(_flag, None)
                chain['steps'].append(current_step)
            current_step = {
                'role': m.group(1).strip().strip('"\''),
                'agent': '',
                'turns': 10,
                'prompt_template': '',
            }
            continue

        if current_step is None:
            continue

        # SOTA flag
        m = re.match(r'^\s+sota:\s*(true|yes|1)', line, re.I)
        if m and current_step is not None:
            current_step['sota'] = True
            continue

        # ── parallel: block handler (must come before generic step-field matchers) ──

        # Inside parallel: block — consume lines before they hit generic field parsers
        if current_step.get('_in_parallel'):
            if re.match(r'^\s+workers:\s*$', line):
                current_step['_parallel_section'] = 'workers'
                continue
            if re.match(r'^\s+judge:\s*$', line):
                current_step['_parallel_section'] = 'judge'
                continue

            if current_step['_parallel_section'] == 'workers':
                m = re.match(r'^\s+-\s+harness:\s*(.+)$', line)
                if m:
                    current_step['parallel']['workers'].append({'harness': m.group(1).strip()})
                    continue
                m = re.match(r'^\s+model:\s*(.+)$', line)
                if m and current_step['parallel']['workers']:
                    current_step['parallel']['workers'][-1]['model'] = m.group(1).strip()
                    continue

            if current_step['_parallel_section'] == 'judge':
                m = re.match(r'^\s+harness:\s*(.+)$', line)
                if m:
                    current_step['parallel']['judge']['harness'] = m.group(1).strip()
                    continue
                m = re.match(r'^\s+model:\s*(.+)$', line)
                if m:
                    current_step['parallel']['judge']['model'] = m.group(1).strip()
                    continue

        # ── Generic step fields (indented with spaces) ──

        m = re.match(r'^\s+agent:\s*(.+)$', line)
        if m:
            current_step['agent'] = m.group(1).strip().strip('"\'')
            continue

        m = re.match(r'^\s+harness:\s*(.+)$', line)
        if m and not current_step.get('_in_parallel'):
            current_step['harness'] = m.group(1).strip().strip('"\'')
            continue

        m = re.match(r'^\s+model:\s*(.+)$', line)
        if m and not current_step.get('_in_parallel'):
            current_step['model'] = m.group(1).strip().strip('"\'')
            continue

        m = re.match(r'^\s+turns:\s*(\d+)', line)
        if m:
            current_step['turns'] = int(m.group(1))
            continue

        m = re.match(r'^\s+prompt_template:\s*(.+)$', line)
        if m:
            value = m.group(1).strip().strip('"\'')
            if value in ('|', '>', '|-', '>-'):
                # Multi-line YAML block scalar — collect continuation lines
                current_step['_collecting_prompt'] = True
                current_step['prompt_template'] = ''
            else:
                current_step['prompt_template'] = value
            continue

        # parallel: block detection (enter parallel mode)
        m = re.match(r'^\s+parallel:\s*$', line)
        if m:
            current_step['parallel'] = {'workers': [], 'judge': {}}
            current_step['_in_parallel'] = True
            current_step['_parallel_section'] = None
            continue

        # Collect multi-line prompt_template continuation lines
        if current_step and current_step.get('_collecting_prompt'):
            # Continuation lines are indented deeper than the key (8+ spaces typically)
            if re.match(r'^\s{6,}', line):
                sep = '\n' if current_step['prompt_template'] else ''
                current_step['prompt_template'] += sep + line.strip()
                continue
            else:
                # End of block — stop collecting, re-process this line
                del current_step['_collecting_prompt']
                # Fall through to re-check this line against other patterns
                m2 = re.match(r'^\s+-\s+role:\s*(.+)$', line)
                if m2:
                    chain['steps'].append(current_step)
                    current_step = {
                        'role': m2.group(1).strip().strip('"\''),
                        'agent': '', 'turns': 10, 'prompt_template': '',
                    }
                continue

    if current_step is not None:
        if '_collecting_prompt' in current_step:
            del current_step['_collecting_prompt']
        if '_in_parallel' in current_step:
            del current_step['_in_parallel']
        if '_parallel_section' in current_step:
            del current_step['_parallel_section']
        chain['steps'].append(current_step)

    return chain


# ── Git diff capture ───────────────────────────────────────────────────────────

def capture_git_diff(workdir):
    """Return a short git diff summary for context between steps."""
    try:
        result = subprocess.run(
            ['git', 'diff', '--stat', 'HEAD'],
            capture_output=True, text=True, cwd=workdir
        )
        return result.stdout.strip()
    except Exception:
        return ''


# ── Step runner ────────────────────────────────────────────────────────────────

def run_step(step, workdir, task, harness, step_index, total_steps, git_context=''):
    """Run a single chain step via the harness. Returns exit code."""
    role = step['role']
    agent = step.get('agent', '')
    turns = step.get('turns', 10)
    template = step.get('prompt_template', '{task}')
    step_harness = step.get('harness', '')
    step_model = step.get('model', '')

    # Skip steps marked sota: true (orchestrator handles these before chain runs)
    if step.get('sota'):
        print(f'\n{"=" * 60}')
        print(f'CHAIN STEP {step_index + 1}/{total_steps}: {role} [SOTA — handled by orchestrator]')
        print(f'{"=" * 60}')
        return 0

    # Substitute {task} and {plan} placeholders
    prompt = template.replace('{task}', task)

    # Inject plan from .delegate/plan.md if {plan} is in the template
    if '{plan}' in prompt:
        plan_path = os.path.join(workdir, '.delegate', 'plan.md')
        if os.path.isfile(plan_path):
            plan_content = open(plan_path).read()
            prompt = prompt.replace('{plan}', plan_content)
        else:
            prompt = prompt.replace('{plan}', '(no plan found — implement based on the task description)')

    # Append git context from previous step if available
    if git_context:
        prompt += f'\n\nContext from previous step (git diff --stat):\n{git_context}'

    # Per-step harness override (from YAML) > env var > default
    harness_name = step_harness or os.environ.get('DELEGATE_CHAIN_HARNESS', 'vibe')

    print(f'\n{"=" * 60}')
    print(f'CHAIN STEP {step_index + 1}/{total_steps}: {role}')
    print(f'  Harness: {harness_name}')
    print(f'  Model  : {step_model or "(default)"}')
    print(f'  Agent  : {agent or "default"}')
    print(f'  Turns  : {turns or "unlimited"}')
    print(f'  Prompt : {prompt[:120]}...' if len(prompt) > 120 else f'  Prompt : {prompt}')
    print(f'{"=" * 60}')

    # Set per-step model override via env var (adapters read this)
    env = os.environ.copy()
    if step_model:
        env['DELEGATE_ACTIVE_MODEL'] = step_model
        env['VIBE_ACTIVE_MODEL'] = step_model
        # Pi uses --model flag; pass via env for the adapter to pick up
        env['PI_MODEL'] = step_model

    # Build delegate command:
    # tools/delegate <harness-name> <workdir> <prompt> [max-turns] [agent]
    # turns=0 means unlimited — omit the arg so delegate uses its default
    cmd = [harness, harness_name, workdir, prompt]
    if turns and turns > 0:
        cmd.append(str(turns))
    if agent:
        cmd.append(agent)

    result = subprocess.run(cmd, env=env)
    return result.returncode


# ── Parallel step runner ───────────────────────────────────────────────────────

def run_parallel_step(step, workdir, task, harness, step_index, total_steps, git_context=''):
    """Run N workers in parallel, judge picks the winner."""

    parallel = step['parallel']
    workers = parallel['workers']
    judge_config = parallel['judge']
    role = step['role']
    template = step.get('prompt_template', '{task}')
    prompt = template.replace('{task}', task)

    # Inject plan from .delegate/plan.md if {plan} is in the template
    if '{plan}' in prompt:
        plan_path = os.path.join(workdir, '.delegate', 'plan.md')
        if os.path.isfile(plan_path):
            prompt = prompt.replace('{plan}', open(plan_path).read())
        else:
            prompt = prompt.replace('{plan}', '(no plan found)')

    if git_context:
        prompt += f'\n\nContext from previous step:\n{git_context}'

    n = len(workers)
    print(f'\n{"=" * 60}')
    print(f'PARALLEL STEP {step_index + 1}/{total_steps}: {role} ({n} workers)')
    for i, w in enumerate(workers):
        print(f'  Worker {i+1}: {w.get("model", "default")} ({w.get("harness", "codex")})')
    print(f'  Judge: {judge_config.get("model", "default")}')
    print(f'{"=" * 60}')

    # Phase 1: Create worktrees
    pid = os.getpid()
    ts = int(time.time() * 1000)
    worktree_base = f'/tmp/delegate-race-{pid}-{ts}'
    os.makedirs(worktree_base, exist_ok=True)

    worktree_info = []  # list of (worktree_path, branch_name, worker_config)

    def cleanup_worktrees():
        for wt_path, branch, _ in worktree_info:
            subprocess.run(['git', 'worktree', 'remove', '--force', wt_path],
                           cwd=workdir, capture_output=True)
            subprocess.run(['git', 'branch', '-D', branch],
                           cwd=workdir, capture_output=True)
        if os.path.exists(worktree_base):
            shutil.rmtree(worktree_base, ignore_errors=True)

    atexit.register(cleanup_worktrees)

    def _signal_cleanup(signum, frame):
        cleanup_worktrees()
        sys.exit(1)
    prev_term = signal.signal(signal.SIGTERM, _signal_cleanup)
    prev_int = signal.signal(signal.SIGINT, _signal_cleanup)

    for i, worker in enumerate(workers):
        # Sanitize role for branch name (replace non-alphanumeric with dash)
        safe_role = re.sub(r'[^a-zA-Z0-9_-]', '-', role)
        branch = f'delegate-race-{safe_role}-{i}-{pid}-{ts}'
        wt_path = os.path.join(worktree_base, f'worker-{i}')
        result = subprocess.run(
            ['git', 'worktree', 'add', '-b', branch, wt_path, 'HEAD'],
            cwd=workdir, capture_output=True, text=True
        )
        if result.returncode != 0:
            print(f'  ERROR: Failed to create worktree for worker {i+1}: {result.stderr.strip()}')
            cleanup_worktrees()
            atexit.unregister(cleanup_worktrees)
            return 1
        worktree_info.append((wt_path, branch, worker))

    # Phase 2: Dispatch all workers in parallel
    script_dir = os.path.dirname(os.path.realpath(__file__))
    delegate_path = os.path.join(script_dir, 'delegate')

    processes = []
    for i, (wt_path, branch, worker) in enumerate(worktree_info):
        w_harness = worker.get('harness', 'codex')
        w_model = worker.get('model', '')

        env = os.environ.copy()
        if w_model:
            env['DELEGATE_ACTIVE_MODEL'] = w_model
            env['VIBE_ACTIVE_MODEL'] = w_model
            env['PI_MODEL'] = w_model
            env['CODEX_MODEL'] = w_model

        # Point logs to the real project, not the throwaway worktree
        env['DELEGATE_WORKDIR'] = workdir

        turns = step.get('turns', 0)
        cmd = [delegate_path, w_harness, wt_path, prompt]
        if turns and turns > 0:
            cmd.append(str(turns))

        proc = subprocess.Popen(cmd, env=env, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        processes.append((i, proc))

    # Phase 3: Wait for all workers
    worker_results = []
    for i, proc in processes:
        try:
            stdout, stderr = proc.communicate(timeout=600)
        except subprocess.TimeoutExpired:
            proc.kill()
            stdout, stderr = proc.communicate()
        wt_path = worktree_info[i][0]

        # Get diff from worktree
        diff_result = subprocess.run(
            ['git', 'diff', 'HEAD'], capture_output=True, text=True, cwd=wt_path
        )
        stat_result = subprocess.run(
            ['git', 'diff', '--stat', 'HEAD'], capture_output=True, text=True, cwd=wt_path
        )

        # Run syntax check
        ast_check = os.path.join(script_dir, 'delegate-ast-check')
        if os.path.isfile(ast_check):
            syntax_result = subprocess.run(
                ['python3', ast_check, wt_path],
                capture_output=True, text=True
            )
            syntax_ok = syntax_result.returncode == 0
        else:
            syntax_ok = True  # no checker available — optimistic

        worker_results.append({
            'index': i,
            'model': worktree_info[i][2].get('model', 'unknown'),
            'exit_code': proc.returncode,
            'diff': diff_result.stdout[:5000],  # cap diff size for judge
            'stat': stat_result.stdout,
            'syntax_ok': syntax_ok,
            'stdout': stdout.decode('utf-8', errors='replace')[-500:],  # last 500 chars
        })

    # Print results table
    print(f'\n  {"Worker":<8} {"Model":<25} {"Exit":<6} {"Syntax":<8} {"Files"}')
    print(f'  {"------":<8} {"-----":<25} {"----":<6} {"------":<8} {"-----"}')
    for wr in worker_results:
        syntax_str = "OK" if wr['syntax_ok'] else "FAIL"
        stat_lines = [l for l in wr['stat'].splitlines() if '|' in l]
        print(f'  {wr["index"]+1:<8} {wr["model"]:<25} {wr["exit_code"]:<6} {syntax_str:<8} {len(stat_lines)}')

    # Phase 4: Filter to successful workers
    successful = [wr for wr in worker_results if wr['exit_code'] == 0]

    if not successful:
        print(f'\n  ALL WORKERS FAILED — skipping judge')
        cleanup_worktrees()
        atexit.unregister(cleanup_worktrees)
        return 1

    if len(successful) == 1:
        print(f'\n  Only worker {successful[0]["index"]+1} succeeded — skipping judge')
        winner = successful[0]
    else:
        # Phase 5: Build judge prompt and call judge
        judge_prompt_parts = [
            'You are a code quality judge. Multiple AI workers attempted the same task.',
            'Pick the SINGLE BEST solution or REJECT ALL if none are acceptable.',
            '',
            '## Original Task',
            prompt[:500],
            '',
        ]

        for wr in successful:
            judge_prompt_parts.append(f'## Worker {wr["index"]+1} ({wr["model"]})')
            judge_prompt_parts.append(f'Syntax: {"OK" if wr["syntax_ok"] else "ERRORS"}')
            judge_prompt_parts.append('```diff')
            judge_prompt_parts.append(wr['diff'][:3000])
            judge_prompt_parts.append('```')
            judge_prompt_parts.append('')

        judge_prompt_parts.append('Respond with EXACTLY one of:')
        judge_prompt_parts.append('WINNER: <number> — followed by your reasoning')
        judge_prompt_parts.append('REJECT_ALL — followed by why none are acceptable')

        judge_prompt = '\n'.join(judge_prompt_parts)

        j_harness = judge_config.get('harness', 'codex')
        j_model = judge_config.get('model', '')

        judge_env = os.environ.copy()
        if j_model:
            judge_env['DELEGATE_ACTIVE_MODEL'] = j_model
            judge_env['CODEX_MODEL'] = j_model

        # Run judge via codex exec directly (read-only, no file changes)
        judge_cmd = ['codex', 'exec', '--json', '-C', workdir]
        if j_model and '/' in j_model:
            judge_cmd += ['-p', j_model.split('/')[0]]
        elif j_model:
            judge_cmd += ['-m', j_model]
        judge_cmd.append(judge_prompt)

        print(f'\n  Running judge ({judge_config.get("model", "default")})...')
        try:
            judge_proc = subprocess.run(
                judge_cmd, capture_output=True, text=True, timeout=120, env=judge_env
            )
        except subprocess.TimeoutExpired:
            print('  Judge timed out — auto-picking winner by score')
            judge_proc = None

        # Extract judge response
        judge_text = ''
        if judge_proc is not None:
            for line in judge_proc.stdout.splitlines():
                try:
                    event = json.loads(line)
                    item = event.get('item', {})
                    if item.get('type') in ('message', 'text'):
                        content = item.get('content', '')
                        if isinstance(content, list):
                            for c in content:
                                if isinstance(c, dict) and c.get('text'):
                                    judge_text += c['text']
                        elif isinstance(content, str):
                            judge_text += content
                except json.JSONDecodeError:
                    continue

        # Parse winner — only look at the LAST line containing WINNER/REJECT
        # to avoid being tricked by echoed diff content
        winner_match = None
        reject_match = None
        for jline in reversed(judge_text.splitlines()):
            if not winner_match:
                winner_match = re.search(r'WINNER:\s*(\d+)', jline)
            if not reject_match:
                reject_match = re.search(r'REJECT_ALL', jline)
            if winner_match or reject_match:
                break

        if reject_match and not winner_match:
            print(f'\n  Judge: REJECT_ALL')
            print(f'  Reason: {judge_text[:200]}')
            cleanup_worktrees()
            atexit.unregister(cleanup_worktrees)
            return 1
        elif winner_match:
            winner_num = int(winner_match.group(1)) - 1  # 0-indexed
            winner_candidates = [wr for wr in successful if wr['index'] == winner_num]
            if winner_candidates:
                winner = winner_candidates[0]
                print(f'\n  Judge: WINNER {winner_num + 1} ({winner["model"]})')
            else:
                # Judge picked a failed worker, fall back to first successful
                winner = successful[0]
                print(f'\n  Judge picked invalid worker, falling back to worker {winner["index"]+1}')
        else:
            # Can't parse judge output — auto-score: prefer syntax_ok, then smallest diff
            winner = sorted(successful, key=lambda w: (not w['syntax_ok'], len(w['diff'])))[0]
            print(f'\n  Judge output unparseable, auto-picked worker {winner["index"]+1}')

    # Phase 6: Apply winner
    winner_wt = worktree_info[winner['index']][0]
    winner_branch = worktree_info[winner['index']][1]

    # Commit in winner worktree
    subprocess.run(['git', 'add', '-A'], cwd=winner_wt, capture_output=True)
    subprocess.run(
        ['git', 'commit', '-m',
         f'delegate-race: {role} (worker {winner["index"]+1}, {winner["model"]})'],
        cwd=winner_wt, capture_output=True
    )

    # Merge into main workdir
    merge_result = subprocess.run(
        ['git', 'merge', winner_branch, '--no-edit'],
        cwd=workdir, capture_output=True, text=True
    )

    if merge_result.returncode != 0:
        # Fallback: checkout theirs entirely
        subprocess.run(['git', 'merge', '--abort'], cwd=workdir, capture_output=True)
        subprocess.run(['git', 'checkout', winner_branch, '--', '.'], cwd=workdir, capture_output=True)
        subprocess.run(['git', 'add', '-A'], cwd=workdir, capture_output=True)
        subprocess.run(
            ['git', 'commit', '-m',
             f'delegate-race: {role} (worker {winner["index"]+1}, forced)'],
            cwd=workdir, capture_output=True
        )

    print(f'\n  Winner merged: worker {winner["index"]+1} ({winner["model"]})')
    print(f'  {winner["stat"]}')

    # Phase 7: Cleanup
    cleanup_worktrees()
    atexit.unregister(cleanup_worktrees)
    signal.signal(signal.SIGTERM, prev_term)
    signal.signal(signal.SIGINT, prev_int)

    return 0


# ── Main ───────────────────────────────────────────────────────────────────────

def main():
    if len(sys.argv) < 2:
        print(__doc__, file=sys.stderr)
        sys.exit(1)

    # delegate-chain <chain-file> [task]  — workdir defaults to cwd
    # delegate-chain <workdir> <chain-file> [task]  — explicit workdir (legacy)
    args = sys.argv[1:]
    if len(args) >= 2 and os.path.isdir(args[0]) and not os.path.isfile(args[0]):
        workdir = args[0]
        chain_file = args[1]
        task = args[2] if len(args) > 2 else None
    else:
        workdir = os.getcwd()
        chain_file = args[0]
        task = args[1] if len(args) > 1 else None

    # Resolve task from env var if not provided
    if not task:
        task = os.environ.get('DELEGATE_CHAIN_TASK', '')
    if not task:
        print('ERROR: No task provided. Pass as 3rd argument or set DELEGATE_CHAIN_TASK.', file=sys.stderr)
        print('Usage: delegate-chain <workdir> <chain-file> <task>', file=sys.stderr)
        sys.exit(1)

    # Resolve workdir
    if not os.path.isdir(workdir):
        print(f'ERROR: workdir does not exist: {workdir}', file=sys.stderr)
        sys.exit(1)

    # Resolve chain file
    if not os.path.isfile(chain_file):
        print(f'ERROR: chain file not found: {chain_file}', file=sys.stderr)
        sys.exit(1)

    # Auto-resolve harness — always tools/delegate relative to this script
    script_dir = os.path.dirname(os.path.realpath(__file__))
    harness = os.path.join(script_dir, 'delegate')
    if not os.path.isfile(harness):
        print(f'ERROR: delegate script not found at: {harness}', file=sys.stderr)
        sys.exit(1)

    # Parse chain
    try:
        chain = parse_chain(chain_file)
    except Exception as e:
        print(f'ERROR: Failed to parse chain file: {e}', file=sys.stderr)
        sys.exit(1)

    if not chain['steps']:
        print('ERROR: Chain file has no steps.', file=sys.stderr)
        sys.exit(1)

    chain_name = chain.get('name', os.path.basename(chain_file))
    total_steps = len(chain['steps'])

    print(f'\n{"#" * 60}')
    print(f'# DELEGATE CHAIN: {chain_name}')
    print(f'# Description   : {chain.get("description", "")}')
    print(f'# Task          : {task}')
    print(f'# Steps         : {total_steps}')
    print(f'# Workdir       : {workdir}')
    print(f'{"#" * 60}')

    chain_start = time.time()
    results = []  # List of (role, exit_code, duration)
    git_context = ''

    for i, step in enumerate(chain['steps']):
        step_start = time.time()

        if 'parallel' in step:
            exit_code = run_parallel_step(
                step=step,
                workdir=workdir,
                task=task,
                harness=harness,
                step_index=i,
                total_steps=total_steps,
                git_context=git_context,
            )
        else:
            exit_code = run_step(
                step=step,
                workdir=workdir,
                task=task,
                harness=harness,
                step_index=i,
                total_steps=total_steps,
                git_context=git_context,
            )

        step_duration = round(time.time() - step_start, 1)
        results.append((step['role'], exit_code, step_duration))

        if exit_code != 0:
            print(f'\n[chain] STEP FAILED: {step["role"]} (exit {exit_code})')
            print(f'[chain] Aborting chain at step {i + 1}/{total_steps}.')
            _print_summary(chain_name, results, total_steps, time.time() - chain_start, failed=True)
            sys.exit(1)

        # Capture git diff as context for the next step
        git_context = capture_git_diff(workdir)

    _print_summary(chain_name, results, total_steps, time.time() - chain_start, failed=False)
    sys.exit(0)


def _print_summary(chain_name, results, total_steps, elapsed, failed):
    """Print chain execution summary."""
    print(f'\n{"=" * 60}')
    print(f'CHAIN SUMMARY: {chain_name}')
    print(f'  Total duration : {elapsed:.1f}s')
    print(f'  Status         : {"FAILED" if failed else "SUCCESS"}')
    print()
    print(f'  {"Step":<16}  {"Exit":>4}  {"Duration":>10}')
    print(f'  {"-" * 16}  {"-" * 4}  {"-" * 10}')
    for role, exit_code, duration in results:
        status = 'OK' if exit_code == 0 else f'FAIL({exit_code})'
        print(f'  {role:<16}  {status:>4}  {duration:>9.1f}s')
    completed = len(results)
    if completed < total_steps:
        remaining = total_steps - completed
        print(f'  ... ({remaining} step(s) not reached)')
    print(f'{"=" * 60}')


