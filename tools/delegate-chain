#!/usr/bin/env python3
"""
delegate-chain — run multi-step delegation workflows where each step's output feeds the next.

Usage:
  delegate-chain <workdir> <chain-file> [harness] [task]

Arguments:
  workdir     Path to the working directory for delegation.
  chain-file  Path to a YAML chain file (see .delegate/chains/).
  harness     Harness script to use (default: tools/vibe-delegate).
  task        Task description. Falls back to DELEGATE_CHAIN_TASK env var.

Chain file format (YAML subset):
  name: <chain-name>
  description: <description>
  steps:
    - role: <role>
      agent: <agent-name>
      turns: <max-turns>
      prompt_template: "<prompt with {task} placeholder>"

Exit codes:
  0  All steps completed successfully.
  1  A step failed (printed which step and exit code).
"""

import sys
import os
import re
import subprocess
import time


# ── YAML subset parser ─────────────────────────────────────────────────────────

def parse_chain(path):
    """Parse a chain YAML file using simple line-by-line regex parsing (no PyYAML)."""
    with open(path) as f:
        lines = f.readlines()

    chain = {'name': '', 'description': '', 'steps': []}
    current_step = None
    in_steps = False

    for raw in lines:
        line = raw.rstrip()
        stripped = line.strip()

        # Skip comments and blank lines
        if not stripped or stripped.startswith('#'):
            continue

        # Top-level keys
        if re.match(r'^name:\s*', line):
            chain['name'] = re.sub(r'^name:\s*', '', line).strip().strip('"\'')
            continue
        if re.match(r'^description:\s*', line):
            chain['description'] = re.sub(r'^description:\s*', '', line).strip().strip('"\'')
            continue

        # steps: section header
        if re.match(r'^steps:\s*$', line):
            in_steps = True
            continue

        if not in_steps:
            continue

        # New step item (starts with "  - role:")
        m = re.match(r'^\s+-\s+role:\s*(.+)$', line)
        if m:
            if current_step is not None:
                chain['steps'].append(current_step)
            current_step = {
                'role': m.group(1).strip().strip('"\''),
                'agent': '',
                'turns': 10,
                'prompt_template': '',
            }
            continue

        if current_step is None:
            continue

        # Step fields (indented with spaces)
        m = re.match(r'^\s+agent:\s*(.+)$', line)
        if m:
            current_step['agent'] = m.group(1).strip().strip('"\'')
            continue

        m = re.match(r'^\s+harness:\s*(.+)$', line)
        if m:
            current_step['harness'] = m.group(1).strip().strip('"\'')
            continue

        m = re.match(r'^\s+model:\s*(.+)$', line)
        if m:
            current_step['model'] = m.group(1).strip().strip('"\'')
            continue

        m = re.match(r'^\s+turns:\s*(\d+)', line)
        if m:
            current_step['turns'] = int(m.group(1))
            continue

        m = re.match(r'^\s+prompt_template:\s*(.+)$', line)
        if m:
            current_step['prompt_template'] = m.group(1).strip().strip('"\'')
            continue

    if current_step is not None:
        chain['steps'].append(current_step)

    return chain


# ── Git diff capture ───────────────────────────────────────────────────────────

def capture_git_diff(workdir):
    """Return a short git diff summary for context between steps."""
    try:
        result = subprocess.run(
            ['git', 'diff', '--stat', 'HEAD'],
            capture_output=True, text=True, cwd=workdir
        )
        return result.stdout.strip()
    except Exception:
        return ''


# ── Step runner ────────────────────────────────────────────────────────────────

def run_step(step, workdir, task, harness, step_index, total_steps, git_context=''):
    """Run a single chain step via the harness. Returns exit code."""
    role = step['role']
    agent = step.get('agent', '')
    turns = step.get('turns', 10)
    template = step.get('prompt_template', '{task}')
    step_harness = step.get('harness', '')
    step_model = step.get('model', '')

    # Substitute {task} placeholder
    prompt = template.replace('{task}', task)

    # Append git context from previous step if available
    if git_context:
        prompt += f'\n\nContext from previous step (git diff --stat):\n{git_context}'

    # Per-step harness override (from YAML) > env var > default
    harness_name = step_harness or os.environ.get('DELEGATE_CHAIN_HARNESS', 'vibe')

    print(f'\n{"=" * 60}')
    print(f'CHAIN STEP {step_index + 1}/{total_steps}: {role}')
    print(f'  Harness: {harness_name}')
    print(f'  Model  : {step_model or "(default)"}')
    print(f'  Agent  : {agent or "default"}')
    print(f'  Turns  : {turns}')
    print(f'  Prompt : {prompt[:120]}...' if len(prompt) > 120 else f'  Prompt : {prompt}')
    print(f'{"=" * 60}')

    # Set per-step model override via env var (adapters read this)
    env = os.environ.copy()
    if step_model:
        env['DELEGATE_ACTIVE_MODEL'] = step_model
        env['VIBE_ACTIVE_MODEL'] = step_model
        # Pi uses --model flag; pass via env for the adapter to pick up
        env['PI_MODEL'] = step_model

    # Build delegate command:
    # tools/delegate <harness-name> <workdir> <prompt> [max-turns] [agent]
    cmd = [harness, harness_name, workdir, prompt, str(turns)]
    if agent:
        cmd.append(agent)

    result = subprocess.run(cmd, env=env)
    return result.returncode


# ── Main ───────────────────────────────────────────────────────────────────────

def main():
    if len(sys.argv) < 3:
        print(__doc__, file=sys.stderr)
        sys.exit(1)

    workdir = sys.argv[1]
    chain_file = sys.argv[2]
    harness = sys.argv[3] if len(sys.argv) > 3 else None
    task = sys.argv[4] if len(sys.argv) > 4 else None

    # Resolve task from env var if not provided as argument
    if not task:
        task = os.environ.get('DELEGATE_CHAIN_TASK', '')
    if not task:
        print('ERROR: No task provided. Pass as 4th argument or set DELEGATE_CHAIN_TASK.', file=sys.stderr)
        sys.exit(1)

    # Resolve workdir
    if not os.path.isdir(workdir):
        print(f'ERROR: workdir does not exist: {workdir}', file=sys.stderr)
        sys.exit(1)

    # Resolve chain file
    if not os.path.isfile(chain_file):
        print(f'ERROR: chain file not found: {chain_file}', file=sys.stderr)
        sys.exit(1)

    # Resolve harness — default to tools/delegate relative to this script
    if not harness:
        script_dir = os.path.dirname(os.path.realpath(__file__))
        harness = os.path.join(script_dir, 'delegate')
    if not os.path.isfile(harness):
        print(f'ERROR: harness not found: {harness}', file=sys.stderr)
        sys.exit(1)

    # Parse chain
    try:
        chain = parse_chain(chain_file)
    except Exception as e:
        print(f'ERROR: Failed to parse chain file: {e}', file=sys.stderr)
        sys.exit(1)

    if not chain['steps']:
        print('ERROR: Chain file has no steps.', file=sys.stderr)
        sys.exit(1)

    chain_name = chain.get('name', os.path.basename(chain_file))
    total_steps = len(chain['steps'])

    print(f'\n{"#" * 60}')
    print(f'# DELEGATE CHAIN: {chain_name}')
    print(f'# Description   : {chain.get("description", "")}')
    print(f'# Task          : {task}')
    print(f'# Steps         : {total_steps}')
    print(f'# Workdir       : {workdir}')
    print(f'{"#" * 60}')

    chain_start = time.time()
    results = []  # List of (role, exit_code, duration)
    git_context = ''

    for i, step in enumerate(chain['steps']):
        step_start = time.time()

        exit_code = run_step(
            step=step,
            workdir=workdir,
            task=task,
            harness=harness,
            step_index=i,
            total_steps=total_steps,
            git_context=git_context,
        )

        step_duration = round(time.time() - step_start, 1)
        results.append((step['role'], exit_code, step_duration))

        if exit_code != 0:
            print(f'\n[chain] STEP FAILED: {step["role"]} (exit {exit_code})')
            print(f'[chain] Aborting chain at step {i + 1}/{total_steps}.')
            _print_summary(chain_name, results, total_steps, time.time() - chain_start, failed=True)
            sys.exit(1)

        # Capture git diff as context for the next step
        git_context = capture_git_diff(workdir)

    _print_summary(chain_name, results, total_steps, time.time() - chain_start, failed=False)
    sys.exit(0)


def _print_summary(chain_name, results, total_steps, elapsed, failed):
    """Print chain execution summary."""
    print(f'\n{"=" * 60}')
    print(f'CHAIN SUMMARY: {chain_name}')
    print(f'  Total duration : {elapsed:.1f}s')
    print(f'  Status         : {"FAILED" if failed else "SUCCESS"}')
    print()
    print(f'  {"Step":<16}  {"Exit":>4}  {"Duration":>10}')
    print(f'  {"-" * 16}  {"-" * 4}  {"-" * 10}')
    for role, exit_code, duration in results:
        status = 'OK' if exit_code == 0 else f'FAIL({exit_code})'
        print(f'  {role:<16}  {status:>4}  {duration:>9.1f}s')
    completed = len(results)
    if completed < total_steps:
        remaining = total_steps - completed
        print(f'  ... ({remaining} step(s) not reached)')
    print(f'{"=" * 60}')


if __name__ == '__main__':
    main()
