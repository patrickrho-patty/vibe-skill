#!/usr/bin/env python3
"""
delegate-contracts — run pre/post condition checks for delegations
Usage: delegate-contracts <pre|post> <workdir> [contract-file]
"""
import sys, os, subprocess, re, json
from pathlib import Path

def parse_contracts(path: Path) -> dict:
    """Simple YAML-subset parser for contracts. No PyYAML needed."""
    text = path.read_text()
    result = {'pre': [], 'post': [], 'timeout': 30}
    current_section = None
    for line in text.splitlines():
        stripped = line.strip()
        if stripped.startswith('#') or not stripped:
            continue
        if stripped in ('pre:', 'post:'):
            current_section = stripped[:-1]
        elif stripped.startswith('timeout:'):
            result['timeout'] = int(stripped.split(':',1)[1].strip())
        elif stripped.startswith('- ') and current_section:
            result[current_section].append(stripped[2:].strip())
    return result

def run_checks(checks: list, workdir: str, timeout: int) -> list:
    """Run each check command, return list of {check, passed, output}."""
    results = []
    for check in checks:
        try:
            r = subprocess.run(
                check, shell=True, cwd=workdir,
                capture_output=True, text=True, timeout=timeout
            )
            passed = r.returncode == 0
            output = (r.stdout + r.stderr).strip()[:500]
        except subprocess.TimeoutExpired:
            passed = False
            output = f"TIMEOUT after {timeout}s"
        except Exception as e:
            passed = False
            output = str(e)[:200]
        results.append({'check': check, 'passed': passed, 'output': output})
        status = 'PASS' if passed else 'FAIL'
        print(f'  [{status}] {check}')
        if not passed and output:
            print(f'         → {output[:120]}')
    return results

def main():
    if len(sys.argv) < 3:
        print("Usage: delegate-contracts <pre|post> <workdir> [contract-file]", file=sys.stderr)
        sys.exit(1)

    phase = sys.argv[1]
    workdir = sys.argv[2]
    contract_file = sys.argv[3] if len(sys.argv) > 3 else None

    if phase not in ('pre', 'post'):
        print(f"ERROR: phase must be 'pre' or 'post', got '{phase}'", file=sys.stderr)
        sys.exit(1)

    # Find contract file
    if contract_file:
        cf = Path(contract_file)
    else:
        cf = Path(workdir) / '.delegate' / 'contracts.yaml'

    if not cf.exists():
        # No contracts = all pass
        print(f"[contracts] No contract file found at {cf} — skipping")
        sys.exit(0)

    contracts = parse_contracts(cf)
    checks = contracts.get(phase, [])
    timeout = contracts.get('timeout', 30)

    if not checks:
        print(f"[contracts] No {phase}-conditions defined — skipping")
        sys.exit(0)

    print(f"=== CONTRACT {phase.upper()} ({len(checks)} checks) ===")
    results = run_checks(checks, workdir, timeout)

    # Write results to stats file if available
    stats_file = os.environ.get('DELEGATE_STATS_FILE', '')
    if stats_file:
        try:
            existing = json.loads(Path(stats_file).read_text())
        except Exception:
            existing = {}
        existing[f'contract_{phase}_results'] = results
        existing[f'contract_{phase}_pass'] = all(r['passed'] for r in results)
        Path(stats_file).write_text(json.dumps(existing))

    # Exit code: 0 if all pass, 1 if any fail
    all_pass = all(r['passed'] for r in results)
    if all_pass:
        print(f"=== CONTRACT {phase.upper()} PASSED ({len(checks)}/{len(checks)}) ===")
        sys.exit(0)
    else:
        failed = sum(1 for r in results if not r['passed'])
        print(f"=== CONTRACT {phase.upper()} FAILED ({failed}/{len(checks)} failed) ===")
        sys.exit(1)

if __name__ == '__main__':
    main()
