#!/usr/bin/env python3
"""delegate-research — Deep web research on a codebase using JINA search and reader APIs.

Usage:
  delegate-research scan <workdir> [--file <path>] [--model <model>]
  delegate-research list <workdir> [--category <cat>] [--severity <level>]
  delegate-research apply <workdir> <finding-id>
  delegate-research dismiss <workdir> <finding-id>
  delegate-research prune <workdir>
"""

import sys
import os
import json
import re
import fcntl
import hashlib
import subprocess
import time
from pathlib import Path
from datetime import datetime, timezone, timedelta

KST = timezone(timedelta(hours=9))

# ── Constants ─────────────────────────────────────────────────────────────────

DEFAULT_MODEL = 'minimax/MiniMax-M2.7'

FILE_EXTENSIONS = {
    '.py', '.js', '.ts', '.tsx', '.jsx', '.go', '.rs', '.java', '.kt',
    '.rb', '.php', '.cpp', '.c', '.h', '.hpp', '.cs', '.swift', '.scala',
    '.sh', '.bash', '.zsh', '.fish', '.lua', '.r', '.jl', '.ml', '.ex',
    '.exs', '.clj', '.cljs', '.hs', '.elm', '.dart', '.vue', '.svelte',
    '.toml', '.yaml', '.yml', '.json', '.dockerfile', '.tf', '.hcl',
}

SKIP_DIRS = {
    '.git', '.svn', '__pycache__', 'node_modules', '.venv', 'venv',
    '.env', 'dist', 'build', '.next', '.nuxt', 'target', 'vendor',
    '.delegate', '.cache', 'coverage', '.pytest_cache', '.mypy_cache',
    '.claude', '.codex', '.agents',
}

# ── JINA integration (via jina-search script) ────────────────────────────────

JINA_SCRIPT = str(Path(__file__).resolve().parent / 'jina-search')


def jina_search(query: str) -> str:
    """Search via JINA using the jina-search script."""
    try:
        result = subprocess.run(
            ['python3', JINA_SCRIPT, 'search', query],
            capture_output=True, text=True, timeout=190
        )
        return result.stdout[:8000] if result.returncode == 0 else f"Search failed: {result.stderr[:200]}"
    except Exception as e:
        return f"Search failed: {e}"


def jina_search_with_retry(query: str) -> str:
    result = jina_search(query)
    if 'Search failed' in result or 'Error' in result:
        time.sleep(3)
        result = jina_search(query)
    return result


def jina_read(url: str) -> str:
    """Read a URL via JINA using the jina-search script."""
    try:
        result = subprocess.run(
            ['python3', JINA_SCRIPT, 'read', url],
            capture_output=True, text=True, timeout=190
        )
        return result.stdout[:4000] if result.returncode == 0 else f"Read failed: {result.stderr[:200]}"
    except Exception as e:
        return f"Read failed: {e}"


def jina_read_with_retry(url: str) -> str:
    result = jina_read(url)
    if 'Read failed' in result or 'Error' in result:
        time.sleep(3)
        result = jina_read(url)
    return result


# ── File discovery ────────────────────────────────────────────────────────────

def discover_files(workdir: str, cap: int = 20) -> list:
    """Walk tree, skip dirs, filter extensions, sort by mtime. Cap at `cap` files."""
    root = Path(workdir)
    candidates = []
    for dirpath, dirnames, filenames in os.walk(root):
        # Skip known noisy directories
        dirnames[:] = [d for d in dirnames if d not in SKIP_DIRS]
        for fname in filenames:
            fpath = Path(dirpath) / fname
            suffix = fpath.suffix.lower()
            # Include files with known extensions, or extensionless scripts
            if suffix in FILE_EXTENSIONS or (not suffix and fpath.stat().st_size < 100_000):
                try:
                    mtime = fpath.stat().st_mtime
                    candidates.append((mtime, fpath))
                except OSError:
                    continue

    # Sort by mtime descending (newest first)
    candidates.sort(key=lambda x: x[0], reverse=True)
    return [str(p) for _, p in candidates[:cap]]


# ── Research JSONL storage ────────────────────────────────────────────────────

def get_research_path(workdir: str) -> Path:
    log = Path(workdir) / '.delegate' / 'research.jsonl'
    log.parent.mkdir(parents=True, exist_ok=True)
    if not log.exists():
        log.touch()
    return log


def load_findings(workdir: str) -> list:
    log = get_research_path(workdir)
    findings = []
    for line in log.read_text().splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            findings.append(json.loads(line))
        except Exception:
            continue
    return findings


def append_findings(workdir: str, new_findings: list):
    """Append new findings to the JSONL file with file locking."""
    if not new_findings:
        return
    log = get_research_path(workdir)
    with open(log, 'a') as f:
        fcntl.flock(f, fcntl.LOCK_EX)
        try:
            for finding in new_findings:
                f.write(json.dumps(finding) + '\n')
            f.flush()
        finally:
            fcntl.flock(f, fcntl.LOCK_UN)


def update_finding(workdir: str, finding_id: str, updates: dict):
    """Read all findings, update the matching one, rewrite the file."""
    log = get_research_path(workdir)
    findings = load_findings(workdir)
    matched = False
    for f in findings:
        if f.get('id', '').startswith(finding_id):
            f.update(updates)
            matched = True
            break
    if not matched:
        print(f"Finding '{finding_id}' not found.", file=sys.stderr)
        sys.exit(1)
    with open(log, 'w') as fh:
        fcntl.flock(fh, fcntl.LOCK_EX)
        try:
            for f in findings:
                fh.write(json.dumps(f) + '\n')
            fh.flush()
        finally:
            fcntl.flock(fh, fcntl.LOCK_UN)


def make_finding_id(file: str, topic: str, finding: str) -> str:
    """SHA-256 of file:topic:finding[:50], first 8 chars."""
    key = f"{file}:{topic}:{finding[:50]}"
    return hashlib.sha256(key.encode('utf-8')).hexdigest()[:8]


# ── Codex exec integration ────────────────────────────────────────────────────

def extract_text(output: str) -> str:
    """Extract text content from codex --json output."""
    text_parts = []
    for line in output.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
            if not isinstance(obj, dict):
                continue
            # Codex JSON format: {"type":"item.completed","item":{"type":"agent_message","text":"..."}}
            item = obj.get('item', {})
            if isinstance(item, dict):
                itype = item.get('type', '')
                if itype in ('message', 'text', 'agent_message'):
                    t = item.get('text', '')
                    if t:
                        text_parts.append(t)
                        continue
            # Fallback: top-level content/text/message
            if 'content' in obj:
                content = obj['content']
                if isinstance(content, list):
                    for c in content:
                        if isinstance(c, dict) and c.get('type') == 'output_text':
                            text_parts.append(c.get('text', ''))
                elif isinstance(content, str):
                    text_parts.append(content)
            elif 'text' in obj:
                text_parts.append(obj['text'])
            elif 'message' in obj:
                msg = obj['message']
                if isinstance(msg, dict):
                    for c in msg.get('content', []):
                        if isinstance(c, dict) and c.get('type') == 'text':
                            text_parts.append(c.get('text', ''))
                elif isinstance(msg, str):
                    text_parts.append(msg)
        except (json.JSONDecodeError, TypeError):
            pass
    return '\n'.join(text_parts).strip()


def run_codex(workdir: str, prompt: str, model: str = DEFAULT_MODEL) -> str:
    """Run codex exec with the given prompt and return extracted text."""
    cmd = ['codex', 'exec', '--json', '-C', workdir, '-s', 'read-only']
    if '/' in model:
        cmd += ['-p', model.split('/')[0]]
    else:
        cmd += ['-m', model]
    cmd.append(prompt)
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=180, stdin=subprocess.DEVNULL)
        return extract_text(result.stdout)
    except FileNotFoundError:
        print("Warning: 'codex' not found in PATH. Skipping model calls.", file=sys.stderr)
        return ''
    except subprocess.TimeoutExpired:
        print("Warning: codex exec timed out.", file=sys.stderr)
        return ''
    except Exception as e:
        print(f"Warning: codex exec error: {e}", file=sys.stderr)
        return ''


# ── Research prompts ──────────────────────────────────────────────────────────

def format_existing_research(existing_findings: list, filepath: str = '') -> str:
    """Format existing findings as context for the model, including dates."""
    relevant = [f for f in existing_findings if f.get('status') not in ('dismissed',)]
    if filepath:
        relevant = [f for f in relevant if f.get('file') == filepath] + \
                   [f for f in relevant if f.get('file') != filepath]
    if not relevant:
        return 'none'
    lines = []
    for f in relevant[:30]:
        date = f.get('timestamp', '?')[:10]
        topic = f.get('topic', '?')
        finding_short = f.get('finding', '')[:100]
        sources = ', '.join(f.get('sources', [])[:2])
        lines.append(f"- [{date}] {topic}: {finding_short} (sources: {sources})")
    return '\n'.join(lines)


def build_topics_prompt(filepath: str, file_content: str, existing_findings: list) -> str:
    existing_context = format_existing_research(existing_findings, filepath)
    return f"""You are a technical researcher. Read this source file and identify topics worth researching for improvements.

FILE: {filepath}
CONTENT: {file_content}

EXISTING RESEARCH (already found — listed with dates and sources):
{existing_context}

INSTRUCTIONS:
- Identify technologies, libraries, patterns, or algorithms in this file
- For each, suggest a search query to find LATEST (2025-2026) best practices
- If a topic was already researched (listed above), ONLY include it if you
  believe there may be NEWER information available (newer papers, newer versions,
  newer techniques published AFTER the date shown)
- Do NOT re-research topics where the existing finding is recent (<14 days old)
  and the sources are current

Return a JSON array:
[{{"topic": "<name>", "query": "<search query for JINA>"}}]

Maximum 5 topics per file. Output ONLY the JSON."""


def build_findings_prompt(filepath: str, topics_and_results: list, existing_findings: list) -> str:
    sections = []
    for item in topics_and_results:
        search = item.get('search', '')[:2000]
        deep = item.get('deep_read', '')[:3000]
        sections.append(
            f"### {item['topic']}\n"
            f"Search results:\n{search}\n"
            f"Deep read:\n{deep}\n"
        )
    topics_str = '\n'.join(sections)
    existing_context = format_existing_research(existing_findings, filepath)
    return f"""You researched these topics for {filepath}. Based on the search results, produce detailed, well-cited findings.

EXISTING RESEARCH (already found — with dates):
{existing_context}

TOPICS AND RESULTS:
{topics_str}

Return a JSON array of findings:
[{{
  "file": "{filepath}",
  "topic": "<what was researched>",
  "category": "optimization|security|bugfix|feature|upgrade|pattern",
  "finding": "<DETAILED multi-paragraph analysis — see rules below>",
  "sources": ["<url1>", "<url2>"],
  "severity": "low|medium|high",
  "effort": "trivial|small|medium|large",
  "novelty": "new|update|duplicate"
}}]

FINDING FORMAT — each finding's "finding" field MUST contain:
1. **Current state**: What the code does now and why it matters (1-2 sentences)
2. **What the research says**: Detailed explanation of the best practice, technique,
   or improvement found. Cite sources INLINE using [N] notation matching the sources
   array, e.g. "According to [1], bootstrap iterations below 1000 produce unreliable
   CIs for heavy-tailed distributions." Include specific numbers, thresholds,
   benchmarks, or code patterns from the sources.
3. **Recommended action**: Concrete steps to implement. Reference exact function
   names, parameters, or code patterns. e.g. "Change `bootstrap_iters=10` to
   `bootstrap_iters=1000` in `_monitor_selection_score()`."
4. **Expected impact**: What improves and by how much (if the sources quantify it).

Each finding should be 150-300 words. Shallow findings like "consider using X"
without evidence or specifics will be rejected by the quality gate.

RULES:
- Every factual claim MUST have an inline citation [N] matching a URL in sources
- sources array: include the actual URLs you are citing (not "local" or made-up URLs)
- Classify novelty: "new" (not previously researched), "update" (newer info than
  existing), "duplicate" (same as existing — DO NOT include these)
- ONLY include findings where novelty is "new" or "update"
- For "update" findings: explain what changed since the previous research
- Output ONLY the JSON"""


# ── JSON extraction ───────────────────────────────────────────────────────────

def extract_json_array(text: str) -> list:
    """Extract a JSON array from model output, tolerating markdown fences and truncation."""
    if not text:
        return []
    text = re.sub(r'```(?:json)?\s*', '', text).strip()
    start = text.find('[')
    if start == -1:
        return []
    end = text.rfind(']')
    if end != -1 and end > start:
        try:
            return json.loads(text[start:end + 1])
        except json.JSONDecodeError:
            pass
    # Truncated JSON — try to salvage by closing brackets
    fragment = text[start:]
    # Find last complete object (ends with })
    last_brace = fragment.rfind('}')
    if last_brace > 0:
        attempt = fragment[:last_brace + 1] + ']'
        try:
            return json.loads(attempt)
        except json.JSONDecodeError:
            pass
    return []


# ── Core per-file research flow ───────────────────────────────────────────────

def build_quality_gate_prompt(findings: list, existing_findings: list) -> str:
    """Build a prompt for the quality gate model to filter findings."""
    existing_context = format_existing_research(existing_findings)
    findings_str = json.dumps(findings, indent=2)
    return f"""You are a research quality gate. Review these findings and classify each one.

EXISTING RESEARCH (what we already know):
{existing_context}

NEW FINDINGS TO EVALUATE:
{findings_str}

For EACH finding, decide:
- "keep": genuinely new, actionable, high-impact information
- "update": same topic as existing but with newer/better information — KEEP but mark as update
- "reject": duplicate of existing research, low-impact, too vague, or not actionable

Return a JSON array with the SAME findings but with an added "gate" field:
[{{"gate": "keep|update|reject", "reason": "<1 sentence why>", ...rest of finding}}]

RULES:
- Be STRICT. Only "keep" findings that a senior engineer would act on
- "update" findings must cite a SOURCE that is NEWER than the existing research date
- Reject anything vague like "consider using X" without specific benchmarks or evidence
- Reject anything that restates what's already in existing research without new info
- Output ONLY the JSON"""


def research_file(workdir: str, filepath: str, model: str, existing_findings: list, quality_model: str = '') -> list:
    """Run the full research flow for one file. Returns new findings."""
    fpath = Path(filepath)
    if not fpath.exists():
        print(f"  File not found: {filepath}", file=sys.stderr)
        return []

    # Read file content (cap 3KB to leave room for model output)
    try:
        file_content = fpath.read_text(errors='replace')[:3072]
    except Exception as e:
        print(f"  Could not read {filepath}: {e}", file=sys.stderr)
        return []

    try:
        rel_path = str(fpath.relative_to(Path(workdir)))
    except ValueError:
        rel_path = filepath

    print(f"  Identifying topics for: {rel_path}")

    # Phase 1: identify topics (pass ALL existing findings for context)
    topics_prompt = build_topics_prompt(rel_path, file_content, existing_findings)
    topics_raw = run_codex(workdir, topics_prompt, model)
    topics = extract_json_array(topics_raw)

    if not topics:
        print(f"  No topics identified (model returned nothing or non-JSON).")
        return []

    print(f"  Found {len(topics)} topic(s): {', '.join(t.get('topic', '?') for t in topics)}")

    # Phase 2: JINA search for each topic
    topics_and_results = []
    for topic_item in topics[:5]:
        topic = topic_item.get('topic', '')
        query = topic_item.get('query', topic)
        if not query:
            continue

        print(f"    Searching: {query}")
        search_result = jina_search_with_retry(query + ' best practices 2026')
        time.sleep(2)  # Rate limit between JINA API calls

        # Extract top 2 URLs from search results
        urls = re.findall(r'https?://[^\s\)\"\'>\]]+', search_result)
        # Deduplicate preserving order
        seen_urls = set()
        unique_urls = []
        for u in urls:
            # Filter out jina's own URLs
            if 'jina.ai' not in u and u not in seen_urls:
                seen_urls.add(u)
                unique_urls.append(u)

        deep_read_parts = []
        for url in unique_urls[:2]:
            print(f"    Deep reading: {url[:80]}")
            page_content = jina_read_with_retry(url)
            deep_read_parts.append(f"URL: {url}\n{page_content}")
            time.sleep(2)  # Rate limit

        topics_and_results.append({
            'topic': topic,
            'query': query,
            'search': search_result,
            'deep_read': '\n\n'.join(deep_read_parts),
        })

    if not topics_and_results:
        return []

    # Phase 3: analyze results to produce findings (with existing research context)
    print(f"  Analyzing results for {rel_path}...")
    findings_prompt = build_findings_prompt(rel_path, topics_and_results, existing_findings)
    findings_raw = run_codex(workdir, findings_prompt, model)
    raw_findings = extract_json_array(findings_raw)

    if not raw_findings:
        print(f"  No actionable findings produced.")
        return []

    # Filter out self-declared duplicates
    raw_findings = [f for f in raw_findings if f.get('novelty') != 'duplicate']

    if not raw_findings:
        print(f"  All findings were duplicates of existing research.")
        return []

    # Phase 4: Quality gate — use a different cheap model to filter
    qmodel = quality_model or os.environ.get('DELEGATE_RESEARCH_QUALITY_MODEL', 'minimax/MiniMax-M2.7')
    print(f"  Running quality gate ({qmodel})...")
    gate_prompt = build_quality_gate_prompt(raw_findings, existing_findings)
    gate_raw = run_codex(workdir, gate_prompt, qmodel)
    gated_findings = extract_json_array(gate_raw)

    # If quality gate fails to parse, fall back to raw findings (mark all as keep)
    if not gated_findings:
        print(f"  Quality gate returned nothing — accepting raw findings")
        for rf in raw_findings:
            rf['gate'] = 'keep'
        gated_findings = raw_findings

    # Only keep findings that passed the gate
    kept = [f for f in gated_findings if f.get('gate') in ('keep', 'update')]
    rejected = len(gated_findings) - len(kept)
    if rejected > 0:
        print(f"  Quality gate rejected {rejected} finding(s)")

    if not kept:
        print(f"  No findings survived quality gate.")
        return []

    # Build structured findings with IDs and timestamps
    now = datetime.now(KST).strftime('%Y-%m-%dT%H:%M:%S+09:00')
    existing_ids = {f.get('id') for f in existing_findings}
    new_findings = []

    for rf in kept:
        finding_text = rf.get('finding', '')
        topic_text = rf.get('topic', '')
        file_text = rf.get('file', rel_path)

        if not finding_text or not topic_text:
            continue

        fid = make_finding_id(file_text, topic_text, finding_text)
        if fid in existing_ids:
            continue

        # Word overlap check against existing findings on same topic
        is_semantic_dup = False
        for ef in existing_findings:
            if ef.get('topic', '').lower() == topic_text.lower() and ef.get('status') != 'dismissed':
                existing_words = set(ef.get('finding', '').lower().split())
                new_words = set(finding_text.lower().split())
                if existing_words and new_words:
                    overlap = len(existing_words & new_words) / max(len(existing_words), len(new_words))
                    if overlap > 0.7 and rf.get('gate') != 'update':
                        is_semantic_dup = True
                        break

        if is_semantic_dup:
            print(f"  Skipping semantic duplicate: {topic_text}")
            continue

        finding = {
            'id': fid,
            'file': file_text,
            'topic': topic_text,
            'category': rf.get('category', 'pattern'),
            'finding': finding_text,
            'sources': rf.get('sources', []),
            'severity': rf.get('severity', 'low'),
            'effort': rf.get('effort', 'medium'),
            'novelty': rf.get('gate', rf.get('novelty', 'new')),
            'timestamp': now,
            'status': 'open',
        }
        new_findings.append(finding)
        existing_ids.add(fid)

    print(f"  -> {len(new_findings)} new finding(s) for {rel_path}")
    return new_findings


# ── Subcommands ───────────────────────────────────────────────────────────────

def load_scan_state(workdir: str) -> dict:
    """Load last scan timestamps per file."""
    state_path = Path(workdir) / '.delegate' / 'research-state.json'
    if state_path.exists():
        try:
            return json.loads(state_path.read_text())
        except Exception:
            pass
    return {}


def save_scan_state(workdir: str, state: dict):
    """Save scan state."""
    state_path = Path(workdir) / '.delegate' / 'research-state.json'
    state_path.parent.mkdir(parents=True, exist_ok=True)
    state_path.write_text(json.dumps(state))


def cmd_scan(workdir: str, file_arg: str = '', model: str = ''):
    """Scan changed files, run research, filter through quality gate, append findings."""
    if not model:
        model = os.environ.get('DELEGATE_RESEARCH_MODEL', DEFAULT_MODEL)

    workdir = os.path.abspath(workdir)
    existing_findings = load_findings(workdir)
    scan_state = load_scan_state(workdir)

    if file_arg:
        files = [os.path.abspath(file_arg)]
    else:
        all_files = discover_files(workdir, cap=50)
        # Filter to files changed since last scan (use relative paths for portability)
        files = []
        for fpath in all_files:
            try:
                mtime = os.path.getmtime(fpath)
                rel = os.path.relpath(fpath, workdir)
                last_scanned = scan_state.get(rel, 0)
                if mtime > last_scanned:
                    files.append(fpath)
            except (OSError, ValueError):
                continue

        if not files and all_files:
            print(f"[delegate-research] No files changed since last scan. Use --file to force.")
            return
        # Still cap at 20 per run
        files = files[:20]

    if not files:
        print("No files to research.")
        return

    print(f"[delegate-research] Scanning {len(files)} changed file(s) with model={model}")
    print(f"[delegate-research] Existing research: {len(existing_findings)} finding(s)")
    total_new = 0

    for filepath in files:
        new_findings = research_file(workdir, filepath, model, existing_findings)
        if new_findings:
            append_findings(workdir, new_findings)
            existing_findings.extend(new_findings)
            total_new += len(new_findings)
        # Update scan timestamp using relative path for portability
        try:
            rel = os.path.relpath(filepath, workdir)
        except ValueError:
            rel = filepath
        scan_state[rel] = time.time()

    save_scan_state(workdir, scan_state)
    print(f"\n[delegate-research] Done. {total_new} new finding(s) appended to .delegate/research.jsonl")


def cmd_list(workdir: str, category: str = '', severity: str = ''):
    """Print open findings, optionally filtered by category or severity."""
    findings = load_findings(workdir)
    open_findings = [f for f in findings if f.get('status', 'open') == 'open']

    if category:
        open_findings = [f for f in open_findings if f.get('category') == category]
    if severity:
        open_findings = [f for f in open_findings if f.get('severity') == severity]

    if not open_findings:
        print("No findings.")
        return

    # Sort by severity (high → medium → low)
    sev_order = {'high': 0, 'medium': 1, 'low': 2}
    open_findings.sort(key=lambda f: (sev_order.get(f.get('severity', 'low'), 3), f.get('timestamp', '')))

    print(f"{'=' * 72}")
    print(f"  RESEARCH FINDINGS  ({len(open_findings)} open)")
    print(f"{'=' * 72}")

    for f in open_findings:
        sev = f.get('severity', '?').upper()
        cat = f.get('category', '?')
        effort = f.get('effort', '?')
        fid = f.get('id', '?')
        date = f.get('timestamp', '?')[:10]

        print(f"\n{'─' * 72}")
        print(f"  [{sev}] {f.get('topic', '?')}")
        print(f"  {fid}  |  {cat}  |  effort: {effort}  |  {date}")
        print(f"  File: {f.get('file', '?')}")
        print(f"{'─' * 72}")

        finding = f.get('finding', '?')
        # Word-wrap the finding text at ~76 chars with indent
        import textwrap
        wrapped = textwrap.fill(finding, width=70, initial_indent='  ', subsequent_indent='  ')
        print(wrapped)

        sources = f.get('sources', [])
        if sources:
            print()
            print("  References:")
            for i, src in enumerate(sources, 1):
                print(f"    [{i}] {src}")

    print(f"\n{'=' * 72}")


def cmd_apply(workdir: str, finding_id: str):
    """Mark a finding as applied."""
    now = datetime.now(KST).strftime('%Y-%m-%dT%H:%M:%S+09:00')
    update_finding(workdir, finding_id, {'status': 'applied', 'applied_at': now})
    print(f"Finding '{finding_id}' marked as applied.")


def cmd_dismiss(workdir: str, finding_id: str):
    """Mark a finding as dismissed."""
    update_finding(workdir, finding_id, {'status': 'dismissed'})
    print(f"Finding '{finding_id}' dismissed.")


def cmd_prune(workdir: str):
    """Remove findings older than 30 days."""
    cutoff = datetime.now(KST) - timedelta(days=30)
    findings = load_findings(workdir)
    kept = []
    removed = 0
    for f in findings:
        ts_str = f.get('timestamp', '')
        try:
            ts = datetime.fromisoformat(ts_str.replace('Z', '+00:00'))
            if ts < cutoff:
                removed += 1
                continue
        except (ValueError, AttributeError):
            pass
        kept.append(f)

    log = get_research_path(workdir)
    with open(log, 'w') as fh:
        fcntl.flock(fh, fcntl.LOCK_EX)
        try:
            for f in kept:
                fh.write(json.dumps(f) + '\n')
            fh.flush()
        finally:
            fcntl.flock(fh, fcntl.LOCK_UN)

    print(f"Pruned {removed} finding(s) older than 30 days. {len(kept)} remaining.")


# ── CLI entry point ───────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]
    if not args:
        print(__doc__, file=sys.stderr)
        sys.exit(1)

    subcmd = args[0]

    rest = args[1:]

    def _resolve_wd(a: list) -> tuple:
        if a and not a[0].startswith('-') and os.path.isdir(a[0]):
            return a[0], a[1:]
        return os.getcwd(), list(a)

    if subcmd == 'scan':
        workdir, rest2 = _resolve_wd(rest)
        file_arg = ''
        model = ''
        i = 0
        while i < len(rest2):
            if rest2[i] == '--file' and i + 1 < len(rest2):
                file_arg = rest2[i + 1]
                i += 2
            elif rest2[i] == '--model' and i + 1 < len(rest2):
                model = rest2[i + 1]
                i += 2
            else:
                i += 1
        cmd_scan(workdir, file_arg, model)

    elif subcmd == 'list':
        workdir, rest2 = _resolve_wd(rest)
        category = ''
        severity = ''
        i = 0
        while i < len(rest2):
            if rest2[i] == '--category' and i + 1 < len(rest2):
                category = rest2[i + 1]
                i += 2
            elif rest2[i] == '--severity' and i + 1 < len(rest2):
                severity = rest2[i + 1]
                i += 2
            else:
                i += 1
        cmd_list(workdir, category, severity)

    elif subcmd == 'apply':
        workdir, rest2 = _resolve_wd(rest)
        if not rest2:
            print("Usage: delegate-research apply [workdir] <finding-id>", file=sys.stderr)
            sys.exit(1)
        cmd_apply(workdir, rest2[0])

    elif subcmd == 'dismiss':
        workdir, rest2 = _resolve_wd(rest)
        if not rest2:
            print("Usage: delegate-research dismiss [workdir] <finding-id>", file=sys.stderr)
            sys.exit(1)
        cmd_dismiss(workdir, rest2[0])

    elif subcmd == 'prune':
        workdir, _ = _resolve_wd(rest)
        cmd_prune(workdir)

    else:
        print(f"Unknown subcommand: {subcmd}", file=sys.stderr)
        print(__doc__, file=sys.stderr)
        sys.exit(1)


if __name__ == '__main__':
    main()
