#!/usr/bin/env bash
# vibe-delegate — Backward-compatibility shim; delegates to tools/delegate vibe
# Usage: vibe-delegate <workdir> <prompt> [max-turns] [agent] [timeout-secs]
#
# This script is kept as a compatibility shim.
# All logic now lives in tools/delegate (generic) + tools/adapters/vibe.

SCRIPT_DIR="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"
exec "$SCRIPT_DIR/delegate" vibe "$@"
